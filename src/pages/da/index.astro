---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import OpeningHours from '@/components/OpeningHours.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'da';
const home = loadContent<any>(locale, 'home');
const site = loadContent<any>(locale, 'site');
---

<Layout title={home.hero.heading} locale={locale}>
  <Hero
    heading={home.hero.heading}
    subheading={home.hero.subheading}
    cta1={home.hero.cta1}
    cta2={home.hero.cta2}
  />

  <section class="section-padding pt-6">
    <div class="container-narrow mx-auto">
      <div class="surface-panel px-6 py-8 sm:px-8 sm:py-10 lg:grid lg:grid-cols-[1.12fr,0.88fr] lg:gap-12 lg:px-10">
        <div>
          <SectionHeading heading={home.intro.heading} align="left" />
          <div class="space-y-5 text-base leading-relaxed text-surface-ink/70">
            {home.intro.text.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
          {home.intro.deliveryNote && (
            <div class="mt-8 rounded-[1.4rem] bg-surface-raised px-5 py-4 text-sm text-surface-ink/72 shadow-ambient">
              <p class="font-semibold text-primary-600">{home.intro.deliveryNote}</p>
            </div>
          )}
        </div>

        <div class="mt-10 space-y-6 lg:mt-0">
          <OpeningHours locale={locale} />
          <div class="editorial-card relative overflow-hidden p-6 sm:p-7">
            <div class="absolute -right-10 top-0 h-28 w-28 rounded-full bg-secondary-100/60 blur-3xl"></div>
            <p class="eyebrow">Kontakt</p>
            <h3 class="mt-5 font-heading text-3xl text-surface-ink">{site.footer.contactUs}</h3>
            <div class="mt-5 space-y-3 text-sm text-surface-ink/68">
              <p>
                <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="font-semibold text-surface-ink transition-colors hover:text-primary-600">
                  {site.phone}
                </a>
              </p>
              <p>
                <a href={`mailto:${site.email}`} class="font-semibold text-surface-ink transition-colors hover:text-primary-600">
                  {site.email}
                </a>
              </p>
              <p>
                {site.address.street}<br />
                {site.address.zip} {site.address.city}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid gap-10 lg:grid-cols-[0.9fr,1.1fr] lg:items-end">
        <div>
          <SectionHeading heading={home.serviceHighlights.heading} align="left" />
          <p class="max-w-md text-base leading-relaxed text-surface-ink/68">
            Vi arbejder med et roligt, kurateret udtryk i alle blomsteropgaver, fra hverdagsbuketter til større anledninger.
          </p>
          <div class="mt-8">
            <a href="/da/firma-bestilling" class="btn-primary !px-8 !py-3.5">
              {site.nav.order}
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          {home.serviceHighlights.items.map((item: any) => (
            <ServiceCard
              title={item.title}
              description={item.description}
              href={`/da/services#${item.anchor}`}
            />
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
