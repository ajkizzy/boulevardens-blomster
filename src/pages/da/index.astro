---
import Layout from '@/layouts/Layout.astro';
import HomeLandingPage from '@/components/HomeLandingPage.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'da';
const home = loadContent<any>(locale, 'home');
const site = loadContent<any>(locale, 'site');
---

<Layout title={home.hero.heading} locale={locale}>
  <HomeLandingPage locale={locale} home={home} site={site} />
</Layout>
