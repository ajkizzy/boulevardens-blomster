---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import OpeningHours from '@/components/OpeningHours.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'da';
const contact = loadContent<any>(locale, 'contact');
const site = loadContent<any>(locale, 'site');
---

<Layout title={contact.heading} locale={locale}>
  <Hero heading={contact.heading} subheading={contact.subheading} compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Map & Info -->
        <div class="space-y-8">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-gray-200 shadow-lg">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=12.24%2C55.64%2C12.28%2C55.66&layer=mapnik&marker=55.6505%2C12.2614"
              class="w-full h-full border-0"
              loading="lazy"
              title="Map"
            ></iframe>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-heading font-semibold text-gray-900 mb-3">{contact.mapHeading}</h3>
              <address class="not-italic text-sm text-gray-600 space-y-1">
                <p class="font-medium text-gray-900">Boulevardens Blomster</p>
                <p>{site.address.street}</p>
                <p>{site.address.zip} {site.address.city}</p>
                <p>{site.address.country}</p>
                <p class="text-gray-500 mt-2">CVR: {site.cvr}</p>
              </address>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-gray-900 mb-3">{site.footer.contactUs}</h3>
              <div class="text-sm text-gray-600 space-y-2">
                <p>
                  <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="hover:text-primary-700 transition-colors font-medium">
                    {site.phone}
                  </a>
                </p>
                <p>
                  <a href={`mailto:${site.email}`} class="hover:text-primary-700 transition-colors">
                    {site.email}
                  </a>
                </p>
              </div>
            </div>
          </div>

          <OpeningHours locale={locale} />
        </div>

        <!-- Contact Form -->
        <div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8">
            <h2 class="font-heading text-2xl font-bold text-gray-900 mb-6">{contact.heading}</h2>
            <div id="contact-form-status" class="hidden mb-5 rounded-xl border border-primary-100 bg-primary-50 px-4 py-3 text-sm text-primary-800"></div>
            <form
              id="contact-form"
              class="space-y-5"
              data-locale={locale}
              data-success-heading={contact.form.successHeading}
              data-success-body={contact.form.successBody}
              data-error={contact.form.error}
            >
              <div>
                <label for="name" class="label-text">{contact.form.name} *</label>
                <input type="text" id="name" name="name" required class="input-field" placeholder={contact.form.namePlaceholder} />
              </div>
              <div>
                <label for="email" class="label-text">{contact.form.email} *</label>
                <input type="email" id="email" name="email" required class="input-field" placeholder={contact.form.emailPlaceholder} />
              </div>
              <div>
                <label for="message" class="label-text">{contact.form.message} *</label>
                <textarea id="message" name="message" required rows="5" class="input-field resize-y" placeholder={contact.form.messagePlaceholder}></textarea>
              </div>
              <button type="submit" class="btn-primary w-full !py-3.5">
                {contact.form.submit}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!status) return;

    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const successHeading = form.dataset.successHeading || '';
    const successBody = form.dataset.successBody || '';
    const errorMessage = form.dataset.error || 'Der opstod en fejl. Prøv venligst igen.';
    const locale = form.dataset.locale || 'da';

    submitButton?.setAttribute('disabled', 'true');

    try {
      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') || ''),
        email: String(formData.get('email') || ''),
        message: String(formData.get('message') || ''),
        locale,
      };

      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error(result.error || errorMessage);
      }

      form.reset();
      status.className =
        'mb-5 rounded-xl border border-primary-100 bg-primary-50 px-4 py-3 text-sm text-primary-800';
      status.innerHTML = `<p class="font-semibold">${successHeading}</p><p class="mt-1">${successBody}</p>`;
    } catch (error) {
      status.className =
        'mb-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700';
      status.textContent =
        error instanceof Error && error.message ? error.message : errorMessage;
    } finally {
      submitButton?.removeAttribute('disabled');
    }
  });
</script>
