---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import OpeningHours from '@/components/OpeningHours.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'da';
const about = loadContent<any>(locale, 'about');
---

<Layout title={about.hero.heading} locale={locale}>
  <Hero heading={about.hero.heading} compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid gap-8 lg:grid-cols-[0.92fr,1.08fr]">
        <div class="surface-panel relative min-h-[360px] overflow-hidden p-6 sm:p-8">
          <div class="absolute -right-10 top-8 h-40 w-40 rounded-full bg-secondary-100/70 blur-3xl"></div>
          <div class="absolute left-6 top-6 rounded-full bg-surface-raised px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-primary-600 shadow-ambient">
            Håndbundne buketter
          </div>
          <div class="absolute bottom-6 left-6 right-12 top-20 rounded-[2rem] bg-gradient-to-br from-primary-100 via-surface-raised to-secondary-100 shadow-ambient"></div>
          <div class="absolute bottom-0 right-0 flex h-[66%] w-[62%] items-center justify-center rounded-[2rem] bg-gradient-to-br from-primary-500 to-primary-300 text-[6rem] text-white/20">
            ✿
          </div>
        </div>

        <div class="surface-panel p-6 sm:p-8">
          <p class="eyebrow">Om os</p>
          <h2 class="mt-5 font-heading text-4xl leading-tight text-surface-ink">{about.intro.heading}</h2>
          <div class="mt-6 space-y-5 text-base leading-relaxed text-surface-ink/70">
            {about.intro.text.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding pt-0">
    <div class="container-narrow mx-auto">
      <div class="surface-panel px-6 py-8 sm:px-8 sm:py-10 lg:grid lg:grid-cols-[1.05fr,0.95fr] lg:gap-10">
        <div>
          <p class="eyebrow">Historien</p>
          <h2 class="mt-5 font-heading text-4xl leading-tight text-surface-ink">{about.story.heading}</h2>
          <div class="mt-6 space-y-5 text-base leading-relaxed text-surface-ink/70">
            {about.story.text.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
        </div>
        <div class="mt-8 space-y-6 lg:mt-0">
          <div class="surface-panel min-h-[280px] overflow-hidden p-6">
            <div class="h-full rounded-[1.75rem] bg-gradient-to-br from-secondary-100 via-surface-raised to-accent-100"></div>
          </div>
          <OpeningHours locale={locale} />
        </div>
      </div>
    </div>
  </section>
</Layout>
