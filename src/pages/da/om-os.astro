---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import OpeningHours from '@/components/OpeningHours.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'da';
const about = loadContent<any>(locale, 'about');
---

<Layout title={about.hero.heading} locale={locale}>
  <Hero heading={about.hero.heading} compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Intro image placeholder -->
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-primary-100 to-primary-200 shadow-lg flex items-center justify-center">
            <!-- TODO: Replace with actual storefront image -->
            <span class="text-6xl opacity-40">🏪</span>
          </div>
        </div>
        <div>
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-gray-900 mb-6">{about.intro.heading}</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            {about.intro.text.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-gray-900 mb-6">{about.story.heading}</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            {about.story.text.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
        </div>
        <div class="space-y-6">
          <!-- TODO: Replace with actual team/shop image -->
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-accent-50 to-warm-200 shadow-lg flex items-center justify-center">
            <span class="text-6xl opacity-40">💐</span>
          </div>
          <OpeningHours locale={locale} />
        </div>
      </div>
    </div>
  </section>
</Layout>
