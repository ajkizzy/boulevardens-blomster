---
import Layout from '@/layouts/Layout.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'da';
const about = loadContent<any>(locale, 'about');
---

<Layout title={about.hero.heading} locale={locale}>
  <section class="px-4 pb-8 pt-10 sm:px-6 sm:pt-12 lg:px-8">
    <div class="container-narrow mx-auto">
      <div class="mx-auto max-w-4xl text-center">
        <div class="flex flex-col items-center">
          <p class="eyebrow">Om os</p>
          <h1 class="mt-5 w-full max-w-[11.4ch] font-heading text-[2.55rem] leading-[0.92] tracking-[-0.05em] text-surface-ink sm:max-w-[9ch] sm:text-[4.7rem] lg:max-w-[8.5ch] lg:text-[5.6rem]">
            <span class="block whitespace-nowrap">Historien bag</span>
            <span class="block italic">Boulevardens</span>
            <span class="block italic">Blomster</span>
          </h1>
        </div>

      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid gap-8 lg:grid-cols-[0.92fr,1.08fr]">
        <div class="surface-panel overflow-hidden p-5 sm:p-6">
          <div class="about-story-visual">
            <img src="/images/lidt-om-os.jpg" alt="Boulevardens Blomster" class="h-full w-full object-cover" />
            <div class="about-story-note">
              <p class="font-heading text-lg leading-tight text-white">Blomster bærer følelser. Vi hjælper dig med at gøre det personligt.</p>
              <p class="mt-3 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/78">Boulevardens Blomster</p>
            </div>
          </div>
        </div>

        <div class="surface-panel p-6 sm:p-8">
          <p class="eyebrow">Om os</p>
          <h2 class="mt-5 font-heading text-4xl leading-tight text-surface-ink">{about.intro.heading}</h2>
          <div class="mt-6 space-y-5 text-base leading-relaxed text-surface-ink/70">
            {about.intro.text.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding pt-0">
    <div class="container-narrow mx-auto">
      <div class="surface-panel px-6 py-8 sm:px-8 sm:py-10 lg:grid lg:grid-cols-[1.05fr,0.95fr] lg:gap-10">
        <div>
          <p class="eyebrow">Historien</p>
          <h2 class="mt-5 font-heading text-4xl leading-tight text-surface-ink">{about.story.heading}</h2>
          <div class="mt-6 space-y-5 text-base leading-relaxed text-surface-ink/70">
            {about.story.text.split('\n\n').map((p: string) => <p>{p}</p>)}
          </div>
        </div>
        <div class="mt-8 lg:mt-0">
          <div class="surface-panel min-h-[520px] overflow-hidden p-6">
            <img src="/images/about-lidt-om-os.jpg" alt="Historien" class="h-full w-full rounded-[1.75rem] object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-story-visual {
    position: relative;
    min-height: 360px;
    height: 100%;
    overflow: hidden;
    border-radius: 1.5rem;
    background: linear-gradient(135deg, #8a684d 0%, #6c4f39 100%);
    box-shadow: 0 20px 50px rgba(26, 28, 25, 0.12);
  }

  .about-story-note {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    max-width: 14rem;
    border-radius: 1.2rem;
    background: rgba(139, 158, 119, 0.92);
    padding: 1rem 1.1rem;
    box-shadow: 0 16px 30px rgba(26, 28, 25, 0.16);
  }
</style>
