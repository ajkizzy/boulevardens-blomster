---
import Hero from '@/components/Hero.astro';
import Layout from '@/layouts/Layout.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'da';
const site = loadContent<any>(locale, 'site');
---

<Layout title="Privatlivspolitik" locale={locale}>
  <Hero heading="Privatlivspolitik" compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto max-w-4xl space-y-10">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-8 text-sm leading-7 text-gray-700">
        <p>
          Denne privatlivspolitik beskriver, hvordan Boulevardens Blomster
          behandler personoplysninger, når du bruger websitet, sender en besked via
          kontaktformularen eller afgiver en bestilling.
        </p>
      </div>

      <div class="space-y-3">
        <h2 class="text-2xl font-bold text-gray-900">Dataansvarlig</h2>
        <p>{site.name}</p>
        <p>{site.address.street}, {site.address.zip} {site.address.city}</p>
        <p>CVR: {site.cvr}</p>
        <p>Email: {site.email}</p>
        <p>Telefon: {site.phone}</p>
      </div>

      <div class="space-y-3">
        <h2 class="text-2xl font-bold text-gray-900">Hvilke oplysninger vi behandler</h2>
        <p>
          Ved kontaktformularer behandler vi navn, emailadresse og den besked, du
          sender.
        </p>
        <p>
          Ved bestillinger behandler vi de oplysninger, du indtaster i formularen,
          herunder leveringsadresse, leveringstidspunkt, telefonnummer,
          emailadresse, korttekst, eventuelle kommentarer og fakturaoplysninger.
        </p>
      </div>

      <div class="space-y-3">
        <h2 class="text-2xl font-bold text-gray-900">Formål</h2>
        <p>Vi bruger oplysningerne til at besvare henvendelser, håndtere bestillinger, sende kvitteringer og følge op på levering og betaling.</p>
        <p>Oplysninger kan også bruges til bogføring, dokumentation og forebyggelse af misbrug.</p>
      </div>

      <div class="space-y-3">
        <h2 class="text-2xl font-bold text-gray-900">Modtagere og databehandlere</h2>
        <p>Online betalinger behandles via Stripe.</p>
        <p>Websitet hostes på Vercel, og formular- samt ordredata kan blive lagret i de systemer, der er nødvendige for drift af websitet.</p>
        <p>Emailkvitteringer og interne notifikationer sendes via virksomhedens valgte emailleverandør.</p>
      </div>

      <div class="space-y-3">
        <h2 class="text-2xl font-bold text-gray-900">Opbevaring</h2>
        <p>Vi opbevarer henvendelser og ordreoplysninger så længe det er nødvendigt for at håndtere sagen og opfylde gældende dokumentations- og bogføringskrav.</p>
      </div>

      <div class="space-y-3">
        <h2 class="text-2xl font-bold text-gray-900">Dine rettigheder</h2>
        <p>Du kan kontakte Boulevardens Blomster for at få indsigt i, rette eller få slettet oplysninger, hvor lovgivningen giver ret til det.</p>
        <p>Du kan også gøre indsigelse mod behandlingen eller anmode om begrænsning, hvis betingelserne er opfyldt.</p>
        <p>Hvis du mener, at dine oplysninger behandles i strid med reglerne, kan du klage til Datatilsynet.</p>
      </div>
    </div>
  </section>
</Layout>
