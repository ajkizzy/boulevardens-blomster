---
import Hero from '@/components/Hero.astro';
import Layout from '@/layouts/Layout.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'en';
const site = loadContent<any>(locale, 'site');
---

<Layout title="Privacy Policy" locale={locale}>
  <Hero heading="Privacy Policy" compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto max-w-4xl space-y-10">
      <div class="surface-panel p-6 sm:p-8 text-sm leading-7 text-surface-ink/72">
        <p>
          This privacy policy explains how Boulevardens Blomster processes personal
          data when you use the website, submit a contact request or place an order.
        </p>
      </div>

      <div class="space-y-3">
        <h2 class="font-heading text-3xl text-surface-ink">Data controller</h2>
        <p>{site.name}</p>
        <p>{site.address.street}, {site.address.zip} {site.address.city}</p>
        <p>VAT / CVR: {site.cvr}</p>
        <p>Email: {site.email}</p>
        <p>Phone: {site.phone}</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-heading text-3xl text-surface-ink">What data we process</h2>
        <p>
          For contact forms we process your name, email address and the message you
          submit.
        </p>
        <p>
          For orders we process the information entered in the form, including the
          delivery address, delivery time, phone number, email address, card text,
          comments and invoice details.
        </p>
      </div>

      <div class="space-y-3">
        <h2 class="font-heading text-3xl text-surface-ink">Purpose</h2>
        <p>We use the information to answer enquiries, handle orders, send acknowledgements and follow up on delivery and payment.</p>
        <p>Information may also be used for bookkeeping, documentation and abuse prevention.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-heading text-3xl text-surface-ink">Recipients and processors</h2>
        <p>Online payments are processed through Stripe.</p>
        <p>The website is hosted on Vercel, and form or order data may be stored in the systems needed to run the website.</p>
        <p>Email acknowledgements and internal notifications are sent through the business' chosen email provider.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-heading text-3xl text-surface-ink">Retention</h2>
        <p>We keep enquiries and order data for as long as necessary to handle the matter and comply with applicable documentation and bookkeeping obligations.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-heading text-3xl text-surface-ink">Your rights</h2>
        <p>You may contact Boulevardens Blomster to request access, correction or deletion of your data where the law gives you that right.</p>
        <p>You may also object to the processing or request restriction if the legal conditions are met.</p>
        <p>If you believe your data is being processed unlawfully, you may lodge a complaint with the Danish Data Protection Agency.</p>
      </div>
    </div>
  </section>
</Layout>
