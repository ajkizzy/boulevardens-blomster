---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import OpeningHours from '@/components/OpeningHours.astro';
import { loadContent } from '@/lib/i18n';

const locale = 'en';
const contact = loadContent<any>(locale, 'contact');
const site = loadContent<any>(locale, 'site');
---

<Layout title={contact.heading} locale={locale}>
  <Hero heading={contact.heading} subheading={contact.subheading} compact />

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[0.86fr,1fr] lg:items-start">
        <div class="space-y-6">
          <div class="surface-panel p-4 sm:p-5">
            <div class="overflow-hidden rounded-[1.5rem] shadow-ambient">
              <iframe
                src="https://www.openstreetmap.org/export/embed.html?bbox=12.24%2C55.64%2C12.28%2C55.66&layer=mapnik&marker=55.6505%2C12.2614"
                class="aspect-[4/3] w-full border-0"
                loading="lazy"
                title="Map"
              ></iframe>
            </div>
          </div>

          <div class="grid items-start gap-6 sm:grid-cols-2">
            <div class="surface-panel self-start p-6">
              <h3 class="font-heading text-3xl text-surface-ink">{contact.mapHeading}</h3>
              <address class="mt-5 not-italic space-y-2 text-sm text-surface-ink/68">
                <p class="font-semibold text-surface-ink">Boulevardens Blomster</p>
                <p>{site.address.street}</p>
                <p>{site.address.zip} {site.address.city}</p>
                <p>{site.address.country}</p>
                <p class="pt-3 text-xs uppercase tracking-[0.18em] text-surface-ink/46">CVR {site.cvr}</p>
              </address>
            </div>

            <div class="surface-panel self-start p-6">
              <h3 class="font-heading text-3xl text-surface-ink">{site.footer.contactUs}</h3>
              <div class="mt-5 space-y-3 text-sm text-surface-ink/68">
                <p>
                  <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="font-semibold text-surface-ink transition-colors hover:text-primary-600">
                    {site.phone}
                  </a>
                </p>
                <p class="min-w-0">
                  <a href={`mailto:${site.email}`} class="break-all font-semibold text-surface-ink transition-colors hover:text-primary-600 sm:break-words [overflow-wrap:anywhere]">
                    {site.email}
                  </a>
                </p>
              </div>
            </div>
          </div>

          <OpeningHours locale={locale} />
        </div>

        <div class="surface-panel self-start p-6 sm:p-8">
          <h2 class="font-heading text-4xl text-surface-ink">{contact.heading}</h2>
          <div id="contact-form-status" class="hidden mb-5 mt-6 rounded-[1.25rem] bg-primary-50 px-4 py-3 text-sm text-primary-700"></div>
          <form
            id="contact-form"
            class="mt-6 space-y-5"
            data-locale={locale}
            data-success-heading={contact.form.successHeading}
            data-success-body={contact.form.successBody}
            data-error={contact.form.error}
          >
            <div>
              <label for="name" class="label-text">{contact.form.name} *</label>
              <input type="text" id="name" name="name" required class="input-field" placeholder={contact.form.namePlaceholder} />
            </div>
            <div>
              <label for="email" class="label-text">{contact.form.email} *</label>
              <input type="email" id="email" name="email" required class="input-field" placeholder={contact.form.emailPlaceholder} />
            </div>
            <div>
              <label for="message" class="label-text">{contact.form.message} *</label>
              <textarea id="message" name="message" required rows="5" class="input-field min-h-[10rem] resize-y [overflow-wrap:anywhere]" placeholder={contact.form.messagePlaceholder}></textarea>
            </div>
            <button type="submit" class="btn-primary w-full !py-3.5">
              {contact.form.submit}
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!status) return;

    const submitButton = form.querySelector('button[type="submit"]');
    const successHeading = form.dataset.successHeading || '';
    const successBody = form.dataset.successBody || '';
    const errorMessage = form.dataset.error || 'An error occurred. Please try again.';
    const locale = form.dataset.locale || 'en';

    submitButton?.setAttribute('disabled', 'true');

    try {
      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') || ''),
        email: String(formData.get('email') || ''),
        message: String(formData.get('message') || ''),
        locale,
      };

      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error(result.error || errorMessage);
      }

      form.reset();
      status.className =
        'mb-5 mt-6 rounded-[1.25rem] bg-primary-50 px-4 py-3 text-sm text-primary-700';
      status.innerHTML = `<p class="font-semibold">${successHeading}</p><p class="mt-1">${successBody}</p>`;
    } catch (error) {
      status.className =
        'mb-5 mt-6 rounded-[1.25rem] bg-secondary-100 px-4 py-3 text-sm text-secondary-700';
      status.textContent =
        error instanceof Error && error.message ? error.message : errorMessage;
    } finally {
      submitButton?.removeAttribute('disabled');
    }
  });
</script>
