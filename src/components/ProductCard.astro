---
interface Props {
  name: string;
  description: string;
  price: number;
  priceLabel: string;
  id: string;
}

const { name, description, price, priceLabel, id } = Astro.props;
---

<div class="editorial-card flex flex-col p-5 transition-all duration-300 hover:-translate-y-1" data-product-id={id}>
  <!-- TODO: Replace with actual product image -->
  <div class="aspect-[4/3] rounded-lg overflow-hidden bg-gradient-to-br from-accent-50 to-primary-50 mb-4 flex items-center justify-center">
    <span class="text-4xl opacity-40">💐</span>
  </div>
  <h4 class="font-heading text-2xl text-surface-ink">{name}</h4>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-surface-ink/68">{description}</p>
  <p class="mt-4 text-lg font-semibold text-primary-600">
    {price},00 <span class="text-sm font-normal text-surface-ink/46">{priceLabel}</span>
  </p>
</div>
