---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
const actionLabel = Astro.url.pathname.startsWith('/en') ? 'Explore' : 'Udforsk';
---

<a
  href={href}
  class="group relative block overflow-hidden rounded-[1.6rem] bg-surface-raised p-6 shadow-ambient transition-all duration-300 hover:-translate-y-1"
>
  <div class="absolute inset-x-6 top-0 h-1 rounded-full bg-primary-300"></div>
  <h3 class="relative pt-4 font-heading text-[1.7rem] leading-tight text-surface-ink transition-colors group-hover:text-primary-600">
    {title}
  </h3>
  <p class="relative mt-3 max-w-[28ch] text-sm leading-relaxed text-surface-ink/68">
    {description}
  </p>
  <span class="relative mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary-600">
    {actionLabel}
    <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
