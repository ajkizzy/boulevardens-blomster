---
interface Props {
  heading: string;
  subheading?: string;
  align?: 'left' | 'center';
  id?: string;
}

const { heading, subheading, align = 'center', id } = Astro.props;
---

<div id={id} class:list={[
  "mb-12 sm:mb-14 scroll-mt-28",
  align === 'center' ? 'text-center' : ''
]}>
  <h2 class="font-heading text-4xl font-semibold leading-tight tracking-[-0.02em] text-surface-ink sm:text-5xl">
    {heading}
  </h2>
  {subheading && (
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-surface-ink/68" class:list={[align === 'center' && 'mx-auto']}>
      {subheading}
    </p>
  )}
</div>
