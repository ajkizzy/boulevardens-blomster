---
import { getNavLinks, loadContent } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import ShowcasePlaceholder from '@/components/ShowcasePlaceholder.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const about = loadContent<any>(locale, 'about');
const nav = getNavLinks(locale);

const text = locale === 'en'
  ? {
      eyebrow: 'Our journey',
      introTitle: 'The story behind Boulevardens Blomster',
      craftTitle: 'The shop and the craft',
      teamEyebrow: 'Meet the team',
      teamTitle: 'The people behind the shop',
      teamBody:
        'We believe flowers should feel personal, calm and well made. Every arrangement is prepared with care in the shop in Høje Taastrup.',
      valuesTitle: 'Our values',
      valuesBody: 'Warm service, dependable quality and bouquets that fit the occasion without feeling overdone.',
      sustainabilityTitle: 'Sustainability',
      sustainabilityBody: 'We choose flowers thoughtfully through the seasons and reuse packaging and props where we can.',
      ctaTitle: 'Let us create something beautiful together',
      ctaBody: 'Whether it is for a wedding, a company event or a bouquet for the day, we are ready to help.',
      servicesCta: 'See our services',
      contactCta: 'Contact us',
      statOneLabel: 'Fresh flowers',
      statOneValue: '100%',
      statTwoLabel: 'Local craft',
      statTwoValue: 'Høje Taastrup',
    }
  : {
      eyebrow: 'Vores rejse',
      introTitle: 'Historien bag Boulevardens Blomster',
      craftTitle: 'Butikken og håndværket',
      teamEyebrow: 'Mød teamet',
      teamTitle: 'Menneskene bag butikken',
      teamBody:
        'Vi tror på blomster, der føles personlige, rolige og veludførte. Hver buket bliver lavet med omtanke her i butikken i Høje Taastrup.',
      valuesTitle: 'Vores værdier',
      valuesBody: 'Varm service, sikker kvalitet og buketter der passer til anledningen uden at blive for meget.',
      sustainabilityTitle: 'Bæredygtighed',
      sustainabilityBody: 'Vi vælger blomster med omtanke gennem sæsonerne og genbruger emballage og materialer, hvor det giver mening.',
      ctaTitle: 'Lad os skabe noget smukt sammen',
      ctaBody: 'Uanset om det er til bryllup, virksomhed eller en buket til hverdagen, står vi klar til at hjælpe.',
      servicesCta: 'Se vores services',
      contactCta: 'Kontakt os',
      statOneLabel: 'Sæsonens friske blomster',
      statOneValue: '100%',
      statTwoLabel: 'Lokalt håndværk',
      statTwoValue: 'Høje Taastrup',
    };

const introParagraphs = about.intro.text.split('\n\n').filter(Boolean);
const storyParagraphs = about.story.text.split('\n\n').filter(Boolean);
---

<section class="section-padding pt-8 sm:pt-12">
  <div class="container-narrow mx-auto">
    <section>
      <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-primary-600">
        {text.eyebrow}
      </p>
      <div class="mt-4 grid gap-6 lg:grid-cols-[0.9fr,1.1fr] lg:items-end">
        <h1 class="max-w-2xl font-heading text-5xl leading-[0.94] tracking-[-0.04em] text-surface-ink sm:text-6xl">
          {about.hero.heading}
        </h1>
        <p class="max-w-2xl text-base leading-8 text-surface-ink/72">
          {introParagraphs[0]}
        </p>
      </div>

      <div class="mt-8">
        <ShowcasePlaceholder title={about.hero.heading} eyebrow={text.eyebrow} tone="sage" size="wide" />
      </div>
    </section>

    <section class="mt-20 grid gap-8 lg:grid-cols-[0.98fr,0.82fr] lg:items-start">
      <div>
        <h2 class="font-heading text-4xl leading-tight text-surface-ink sm:text-[3rem]">
          {text.craftTitle}
        </h2>
        <div class="mt-5 space-y-4 text-base leading-8 text-surface-ink/72">
          {storyParagraphs.map((paragraph: string) => <p>{paragraph}</p>)}
        </div>

        <div class="mt-10 grid gap-6 sm:grid-cols-2">
          <div>
            <p class="font-heading text-3xl text-surface-ink">{text.statOneValue}</p>
            <p class="mt-2 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-surface-ink/52">
              {text.statOneLabel}
            </p>
          </div>
          <div>
            <p class="font-heading text-3xl text-surface-ink">{text.statTwoValue}</p>
            <p class="mt-2 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-surface-ink/52">
              {text.statTwoLabel}
            </p>
          </div>
        </div>
      </div>

      <div class="space-y-5">
        <ShowcasePlaceholder title={about.intro.heading} eyebrow={locale === 'en' ? 'In the shop' : 'I butikken'} tone="rose" size="portrait" align="bottom-right" />
        <div class="editorial-card max-w-[18rem] px-5 py-4 text-sm italic leading-7 text-surface-ink/66">
          “{locale === 'en' ? 'We let the flowers speak for themselves and help them do it well.' : 'Vi lader blomsterne tale for sig selv og hjælper dem godt på vej.'}”
        </div>
      </div>
    </section>

    <section class="mt-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-primary-600">
          {text.teamEyebrow}
        </p>
        <h2 class="mt-4 font-heading text-4xl text-surface-ink sm:text-[3rem]">
          {text.teamTitle}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-surface-ink/72">
          {text.teamBody}
        </p>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-[1.02fr,0.98fr]">
        <ShowcasePlaceholder title={text.teamTitle} eyebrow={text.teamEyebrow} tone="amber" size="landscape" />
        <div class="grid gap-5">
          <div class="editorial-card px-6 py-6">
            <h3 class="font-heading text-2xl text-surface-ink">{text.valuesTitle}</h3>
            <p class="mt-3 text-base leading-8 text-surface-ink/72">{text.valuesBody}</p>
          </div>
          <div class="rounded-[1.8rem] bg-primary-600 px-6 py-6 text-white shadow-[0_20px_50px_rgba(82,99,73,0.25)]">
            <h3 class="font-heading text-2xl">{text.sustainabilityTitle}</h3>
            <p class="mt-3 text-base leading-8 text-white/86">{text.sustainabilityBody}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-24">
      <div class="surface-panel px-6 py-12 text-center sm:px-10">
        <h2 class="font-heading text-4xl leading-tight text-surface-ink sm:text-[3.2rem]">
          {text.ctaTitle}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-surface-ink/70">
          {text.ctaBody}
        </p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a href={nav.services.href} class="btn-primary !px-6 !py-3">
            {text.servicesCta}
          </a>
          <a href={nav.contact.href} class="btn-secondary !px-6 !py-3">
            {text.contactCta}
          </a>
        </div>
      </div>
    </section>
  </div>
</section>
