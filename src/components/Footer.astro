---
import { loadContent } from '@/lib/i18n';
import { getPrivacyPagePath, getTermsPagePath } from '@/lib/config';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const site = loadContent<any>(locale, 'site');
const termsHref = getTermsPagePath(locale);
const privacyHref = getPrivacyPagePath(locale);
---

<footer class="bg-gray-900 text-gray-300">
  <div class="container-narrow mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <h3 class="font-heading text-xl text-white font-semibold mb-3">Boulevardens Blomster</h3>
        <p class="text-sm text-gray-400 leading-relaxed">{site.tagline}</p>
        <div class="flex gap-3 mt-4">
          <a href={site.social.facebook} target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-full bg-gray-800 hover:bg-primary-700 flex items-center justify-center transition-colors"
             aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.5h-4.33C10.24.5,9.5,3.44,9.5,5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4Z"/></svg>
          </a>
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-full bg-gray-800 hover:bg-accent-600 flex items-center justify-center transition-colors"
             aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12,2.16c3.2,0,3.58.01,4.85.07,3.25.15,4.77,1.69,4.92,4.92.06,1.27.07,1.65.07,4.85s-.01,3.58-.07,4.85c-.15,3.23-1.66,4.77-4.92,4.92-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85C2.38,3.92,3.9,2.38,7.15,2.23,8.42,2.17,8.8,2.16,12,2.16ZM12,0C8.74,0,8.33.01,7.05.07c-4.27.2-6.78,2.71-6.98,6.98C.01,8.33,0,8.74,0,12s.01,3.67.07,4.95c.2,4.27,2.71,6.78,6.98,6.98,1.28.06,1.69.07,4.95.07s3.67-.01,4.95-.07c4.27-.2,6.78-2.71,6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.27-2.71-6.78-6.98-6.98C15.67.01,15.26,0,12,0Zm0,5.84A6.16,6.16,0,1,0,18.16,12,6.16,6.16,0,0,0,12,5.84ZM12,16a4,4,0,1,1,4-4A4,4,0,0,1,12,16ZM18.41,4.15a1.44,1.44,0,1,0,1.44,1.44A1.44,1.44,0,0,0,18.41,4.15Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Opening Hours -->
      <div>
        <h4 class="font-heading text-white font-semibold mb-4">{site.hours.title}</h4>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt>{site.hours.weekdays.label}</dt>
            <dd class="text-white font-medium">{site.hours.weekdays.time}</dd>
          </div>
          <div class="flex justify-between">
            <dt>{site.hours.saturday.label}</dt>
            <dd class="text-white font-medium">{site.hours.saturday.time}</dd>
          </div>
          <div class="flex justify-between">
            <dt>{site.hours.sunday.label}</dt>
            <dd class="text-white font-medium">{site.hours.sunday.time}</dd>
          </div>
        </dl>
      </div>

      <!-- Find Us -->
      <div>
        <h4 class="font-heading text-white font-semibold mb-4">{site.footer.findUs}</h4>
        <address class="not-italic text-sm space-y-1">
          <p>{site.address.street}</p>
          <p>{site.address.zip} {site.address.city}</p>
          <p class="text-gray-500 text-xs mt-2">CVR: {site.cvr}</p>
        </address>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading text-white font-semibold mb-4">{site.footer.contactUs}</h4>
        <div class="text-sm space-y-2">
          <p>
            <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="hover:text-white transition-colors">
              {site.phone}
            </a>
          </p>
          <p>
            <a href={`mailto:${site.email}`} class="hover:text-white transition-colors break-all">
              {site.email}
            </a>
          </p>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-gray-500">
      <p>&copy; {new Date().getFullYear()} Boulevardens Blomster</p>
      <div class="flex items-center gap-4">
        <a href={termsHref} class="hover:text-gray-300 transition-colors">{site.footer.terms}</a>
        <a href={privacyHref} class="hover:text-gray-300 transition-colors">{site.footer.privacy}</a>
      </div>
    </div>
  </div>
</footer>
