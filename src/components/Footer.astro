---
import { loadContent } from '@/lib/i18n';
import { getPrivacyPagePath, getTermsPagePath } from '@/lib/config';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const site = loadContent<any>(locale, 'site');
const termsHref = getTermsPagePath(locale);
const privacyHref = getPrivacyPagePath(locale);
const footerText = locale === 'en'
  ? 'Flowers for everyday moments, special days, and businesses.'
  : 'Blomster til hverdag, mærkedage og virksomheder.';
---

<footer class="px-4 pb-6 pt-10 sm:px-6 lg:px-8">
  <div class="container-narrow mx-auto">
    <div class="surface-panel overflow-hidden px-6 py-10 sm:px-10 sm:py-12">
      <div class="grid items-start gap-6 md:grid-cols-2 xl:grid-cols-[1.08fr,0.95fr,0.78fr,0.82fr]">
        <div class="min-w-0 rounded-[1.5rem] bg-surface-raised p-6 shadow-ambient sm:p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary-600">Boulevardens Blomster</p>
          <h3 class="mt-4 font-heading text-3xl leading-tight text-surface-ink">
            {footerText}
          </h3>
          <p class="mt-4 max-w-md text-sm leading-relaxed text-surface-ink/68">{site.tagline}</p>
          <div class="mt-6 flex gap-3">
            <a
              href={site.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface text-primary-600 transition-colors hover:bg-primary-100"
              aria-label="Facebook"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.5h-4.33C10.24.5,9.5,3.44,9.5,5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4Z"/></svg>
            </a>
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface text-secondary-500 transition-colors hover:bg-secondary-100"
              aria-label="Instagram"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12,2.16c3.2,0,3.58.01,4.85.07,3.25.15,4.77,1.69,4.92,4.92.06,1.27.07,1.65.07,4.85s-.01,3.58-.07,4.85c-.15,3.23-1.66,4.77-4.92,4.92-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85C2.38,3.92,3.9,2.38,7.15,2.23,8.42,2.17,8.8,2.16,12,2.16ZM12,0C8.74,0,8.33.01,7.05.07c-4.27.2-6.78,2.71-6.98,6.98C.01,8.33,0,8.74,0,12s.01,3.67.07,4.95c.2,4.27,2.71,6.78,6.98,6.98,1.28.06,1.69.07,4.95.07s3.67-.01,4.95-.07c4.27-.2,6.78-2.71,6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.27-2.71-6.78-6.98-6.98C15.67.01,15.26,0,12,0Zm0,5.84A6.16,6.16,0,1,0,18.16,12,6.16,6.16,0,0,0,12,5.84ZM12,16a4,4,0,1,1,4-4A4,4,0,0,1,12,16ZM18.41,4.15a1.44,1.44,0,1,0,1.44,1.44A1.44,1.44,0,0,0,18.41,4.15Z"/></svg>
            </a>
          </div>
        </div>

        <div class="min-w-0 self-start rounded-[1.5rem] bg-surface-raised px-6 py-6 shadow-ambient">
          <h4 class="font-heading text-[1.9rem] text-surface-ink">{site.hours.title}</h4>
          <dl class="mt-5 space-y-4 text-sm text-surface-ink/68">
            <div class="grid grid-cols-[minmax(0,1fr),auto] gap-4">
              <dt class="min-w-0">{site.hours.weekdays.label}</dt>
              <dd class="whitespace-nowrap font-semibold text-surface-ink">{site.hours.weekdays.time}</dd>
            </div>
            <div class="grid grid-cols-[minmax(0,1fr),auto] gap-4">
              <dt class="min-w-0">{site.hours.saturday.label}</dt>
              <dd class="whitespace-nowrap font-semibold text-surface-ink">{site.hours.saturday.time}</dd>
            </div>
            <div class="grid grid-cols-[minmax(0,1fr),auto] gap-4">
              <dt class="min-w-0">{site.hours.sunday.label}</dt>
              <dd class="whitespace-nowrap font-semibold text-surface-ink">{site.hours.sunday.time}</dd>
            </div>
          </dl>
        </div>

        <div class="min-w-0 self-start rounded-[1.5rem] bg-surface-raised px-6 py-6 shadow-ambient">
          <h4 class="font-heading text-[1.9rem] text-surface-ink">{site.footer.findUs}</h4>
          <address class="mt-5 not-italic space-y-2 text-sm text-surface-ink/68">
            <p>{site.address.street}</p>
            <p>{site.address.zip} {site.address.city}</p>
            <p>{site.address.country}</p>
            <p class="pt-3 text-xs uppercase tracking-[0.18em] text-surface-ink/46">CVR {site.cvr}</p>
          </address>
        </div>

        <div class="min-w-0 self-start rounded-[1.5rem] bg-surface-raised px-6 py-6 shadow-ambient">
          <h4 class="font-heading text-[1.9rem] text-surface-ink">{site.footer.contactUs}</h4>
          <div class="mt-5 space-y-3 text-sm text-surface-ink/68">
            <p>
              <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="font-semibold text-surface-ink transition-colors hover:text-primary-600">
                {site.phone}
              </a>
            </p>
            <p class="min-w-0">
              <a href={`mailto:${site.email}`} class="break-all font-semibold text-surface-ink transition-colors hover:text-primary-600 sm:break-words [overflow-wrap:anywhere]">
                {site.email}
              </a>
            </p>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-col gap-3 text-xs text-surface-ink/52 sm:flex-row sm:items-center sm:justify-between">
        <p>&copy; {new Date().getFullYear()} Boulevardens Blomster</p>
        <div class="flex flex-wrap items-center gap-4">
          <a href={termsHref} class="transition-colors hover:text-surface-ink">{site.footer.terms}</a>
          <a href={privacyHref} class="transition-colors hover:text-surface-ink">{site.footer.privacy}</a>
        </div>
      </div>
    </div>
  </div>
</footer>
