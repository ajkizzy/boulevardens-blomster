---
import { getNavLinks, loadContent } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import ShowcasePlaceholder from '@/components/ShowcasePlaceholder.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const services = loadContent<any>(locale, 'services');
const nav = getNavLinks(locale);
const [bouquets, weddings, funerals, holidays, gifts] = services.sections;

const text = locale === 'en'
  ? {
      badge: 'Crafted with care',
      bouquetBullets: [
        'Local delivery in Taastrup',
        'Hand-tied bouquets for the day',
        'Card greeting included',
      ],
      orderNow: 'Order now',
      bookTalk: 'Book a consultation',
      directContact: 'Contact us directly',
      seeSelection: 'See selection',
      farewellCards: ['Casket flowers', 'Wreaths', 'Sympathy bouquets'],
      holidayHeading: 'Seasonal highlights',
      holidayCards: ['Mother’s Day', 'Valentine', 'Christmas', 'Easter'],
      holidayIntro: 'We help set the tone for the year’s special days.',
      giftSplit: ['Sweet treats', 'Gift baskets'],
    }
  : {
      badge: 'Skabt med passion',
      bouquetBullets: [
        'Lokal levering i Taastrup',
        'Håndbundne buketter efter dagen',
        'Personlig hilsen med i buketten',
      ],
      orderNow: 'Bestil nu',
      bookTalk: 'Tal med os om brylluppet',
      directContact: 'Kontakt os direkte',
      seeSelection: 'Se udvalg',
      farewellCards: ['Kistepynt', 'Kranse', 'Bårebuketter'],
      holidayHeading: 'Årets Højtider',
      holidayCards: ['Mors Dag', 'Valentine', 'Jul', 'Påske'],
      holidayIntro: 'Vi hjælper med at sætte stemningen omkring årets særlige dage.',
      giftSplit: ['Søde sager', 'Luksus varer'],
    };

const heroCopy = bouquets.text.split('\n\n')[0];
const weddingCopy = weddings.text.split('\n\n').slice(0, 2);
const funeralCopy = funerals.text.split('\n\n').slice(0, 2);
const giftCopy = gifts.text.split('\n\n').slice(0, 2);
---

<section class="section-padding pt-8 sm:pt-12">
  <div class="container-narrow mx-auto">
    <header class="mx-auto max-w-3xl text-center">
      <span class="inline-flex rounded-full bg-surface-mid px-4 py-2 text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-primary-600">
        {text.badge}
      </span>
      <h1 class="mt-5 font-heading text-5xl tracking-[-0.04em] text-surface-ink sm:text-6xl">
        {services.heading}
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-surface-ink/70 sm:text-lg">
        {services.subheading}
      </p>
    </header>

    <nav class="mt-8 border-y border-surface-ink/8 py-4">
      <ul class="scrollbar-hide flex gap-5 overflow-x-auto text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-surface-ink/52 sm:justify-center">
        {services.sections.map((section: any) => (
          <li>
            <a href={`#${section.id}`} class="whitespace-nowrap transition-colors hover:text-primary-600">
              {locale === 'da' && section.id === 'begravelse' ? 'Begravelse' : section.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="mt-10 space-y-20 sm:space-y-24">
      <section id={bouquets.id} class="scroll-mt-28 grid gap-8 lg:grid-cols-[1.02fr,0.98fr] lg:items-center">
        <ShowcasePlaceholder title={bouquets.title} eyebrow={text.badge} tone="rose" size="landscape" image="/images/forside-service-buketter.jpg" />
        <div>
          <h2 class="font-heading text-4xl leading-tight text-surface-ink sm:text-[3.2rem]">{bouquets.title}</h2>
          <p class="mt-5 text-base leading-8 text-surface-ink/72">
            {heroCopy}
          </p>
          <ul class="mt-6 space-y-3">
            {text.bouquetBullets.map((item) => (
              <li class="flex items-start gap-3 text-sm text-surface-ink/72">
                <span class="mt-1 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-primary-600/12 text-primary-600">
                  <svg viewBox="0 0 20 20" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M5 10.2 8.1 13.3 15 6.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a href={nav.order.href} class="btn-primary mt-8 !px-5 !py-3">
            {text.orderNow}
          </a>
        </div>
      </section>

      <section id={weddings.id} class="scroll-mt-28 grid gap-8 lg:grid-cols-[0.92fr,1.08fr] lg:items-center">
        <div>
          <h2 class="font-heading text-4xl leading-tight text-surface-ink sm:text-[3rem]">{weddings.title}</h2>
          <div class="mt-5 space-y-4 text-base leading-8 text-surface-ink/72">
            {weddingCopy.map((paragraph: string) => <p>{paragraph}</p>)}
          </div>
          <a href={nav.contact.href} class="btn-secondary mt-8 !px-5 !py-3">
            {text.bookTalk}
          </a>
        </div>
        <div class="relative overflow-hidden rounded-[1.8rem] shadow-[0_24px_60px_rgba(26,28,25,0.1)] aspect-[16/8]">
          <div class="bryllup-slideshow relative h-full w-full">
            <img src="/images/bryllup2.jpg" alt="Bryllup 1" class="bryllup-slide absolute inset-0 h-full w-full object-cover opacity-100 transition-opacity duration-500" style="object-position: center 55%" />
            <img src="/images/forside-s-bryllupper.jpg" alt="Bryllup 2" class="bryllup-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500" style="object-position: center 55%" />
            <img src="/images/bryllup1.jpg" alt="Bryllup 3" class="bryllup-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500" style="object-position: center 55%" />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <div class="absolute bottom-6 right-6 sm:right-6 max-w-[16rem] rounded-[1.35rem] bg-black/25 px-4 py-2 shadow-[0_16px_40px_rgba(26,28,25,0.14)] backdrop-blur wedding-text-box">
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white mb-0">
              {locale === 'en' ? 'Elegant entrance' : 'Elegant ankomst'}
            </p>
            <p class="font-heading text-2xl leading-tight text-white mt-0">
              {weddings.title}
            </p>
          </div>
        </div>
      </section>

      <section id={funerals.id} class="scroll-mt-28 text-center">
        <h2 class="font-heading text-4xl leading-tight text-surface-ink sm:text-[3.1rem]">{funerals.title}</h2>
        <p class="mx-auto mt-4 max-w-3xl text-base leading-8 text-surface-ink/72">
          {funeralCopy[0]}
        </p>
        <div class="mt-8 grid gap-4 lg:grid-cols-[0.5fr,2.08fr] funeral-grid-desktop">
          <div class="grid gap-3 auto-rows-max">
            <ShowcasePlaceholder title={locale === 'en' ? 'Wreaths' : 'Kranse'} image="/images/krans.jpg" backgroundPosition="center" size="portrait" />
            <div class="max-w-[16rem]">
              <ShowcasePlaceholder title={locale === 'en' ? 'Casket' : 'Kiste'} image="/images/kiste.png" backgroundPosition="center" size="landscape" />
            </div>
          </div>
          <div>
            <ShowcasePlaceholder title={funerals.title} eyebrow={locale === 'en' ? 'Respectful details' : 'Respektfulde detaljer'} tone="olive" size="wide" align="center" image="/images/forside-s-begravelse.jpg" backgroundPosition="center 35%" />
          </div>
        </div>

        <div class="funeral-slideshow-tablet hidden mt-8">
          <div class="relative overflow-hidden rounded-[1.8rem] shadow-[0_24px_60px_rgba(26,28,25,0.1)] aspect-[16/10]">
            <div class="funeral-slideshow relative h-full w-full">
              <img src="/images/forside-s-begravelse.jpg" alt="Et Sidste Farvel" class="funeral-slide absolute inset-0 h-full w-full object-cover opacity-100 transition-opacity duration-500" style="object-position: center 35%" />
              <img src="/images/krans.jpg" alt="Kranse" class="funeral-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500" />
              <img src="/images/kiste.png" alt="Kiste" class="funeral-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500" />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <div class="absolute bottom-6 right-6 max-w-[16rem] rounded-[1.35rem] bg-black/25 px-4 py-2 shadow-[0_16px_40px_rgba(26,28,25,0.14)] backdrop-blur">
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white mb-0">
                {locale === 'en' ? 'Respectful details' : 'Respektfulde detaljer'}
              </p>
              <p class="font-heading text-2xl leading-tight text-white mt-0">
                {funerals.title}
              </p>
            </div>
          </div>
        </div>
        <p class="mx-auto mt-5 max-w-3xl text-sm leading-7 text-surface-ink/60">
          {funeralCopy[1]}
        </p>
        <div class="mx-auto mt-8 grid max-w-3xl gap-3 sm:grid-cols-3">
          {text.farewellCards.map((item) => (
            <div class="editorial-card rounded-[1.25rem] px-3 py-2.5 sm:px-4 sm:py-3">
              <p class="font-heading text-[1.05rem] leading-tight text-surface-ink sm:text-lg text-center">{item}</p>
            </div>
          ))}
        </div>
        <div class="flex justify-center mt-8">
          <a href={nav.contact.href} class="inline-flex text-sm font-semibold uppercase tracking-[0.16em] text-primary-600 transition-colors hover:text-primary-500">
          {text.directContact}
        </a>
        </div>
      </section>

      <section id={holidays.id} class="scroll-mt-28 holidays-section">
        <div class="grid gap-4 lg:grid-cols-[0.76fr,1.24fr] lg:items-end">
          <div>
            <h2 class="font-heading text-4xl leading-tight text-surface-ink sm:text-[3rem]">{text.holidayHeading}</h2>
            <p class="mt-4 max-w-lg text-base leading-8 text-surface-ink/72">
              {text.holidayIntro}
            </p>
          </div>
        </div>

        <div class="relative mt-8 lg:hidden">
          <button
            type="button"
            class="mobile-slider-arrow mobile-slider-prev left-1"
            data-slider-target="holiday-slider"
            aria-label={locale === 'en' ? 'Previous holiday card' : 'Forrige højtidskort'}
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 18l-6-6 6-6" />
            </svg>
          </button>
          <div id="holiday-slider" class="scrollbar-hide -mx-4 flex snap-x snap-mandatory gap-4 overflow-x-auto px-4 pb-2">
            <div class="w-[84%] max-w-[21rem] flex-none snap-center">
              <ShowcasePlaceholder title={text.holidayCards[0]} eyebrow={holidays.title} tone="rose" size="square" image="/images/mors-dag.jpg" backgroundPosition="center 30%" />
            </div>
            <div class="w-[84%] max-w-[21rem] flex-none snap-center">
              <ShowcasePlaceholder title={text.holidayCards[1]} tone="stone" size="square" image="/images/valentine.jpg" backgroundPosition="center 45%" />
            </div>
            <div class="w-[84%] max-w-[21rem] flex-none snap-center">
              <ShowcasePlaceholder title={text.holidayCards[2]} tone="olive" size="square" image="/images/jul.jpg" backgroundPosition="center 75%" />
            </div>
            <div class="w-[84%] max-w-[21rem] flex-none snap-center">
              <ShowcasePlaceholder title={text.holidayCards[3]} tone="amber" size="square" image="/images/paske.jpg" backgroundPosition="center 30%" />
            </div>
          </div>
          <button
            type="button"
            class="mobile-slider-arrow mobile-slider-next right-1"
            data-slider-target="holiday-slider"
            aria-label={locale === 'en' ? 'Next holiday card' : 'Næste højtidskort'}
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 6l6 6-6 6" />
            </svg>
          </button>
        </div>

        <div class="mt-8 hidden gap-4 lg:grid lg:grid-cols-[1.05fr,1fr]">
          <ShowcasePlaceholder title={text.holidayCards[0]} eyebrow={holidays.title} tone="rose" size="portrait" image="/images/mors-dag.jpg" backgroundPosition="center 30%" />
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <ShowcasePlaceholder title={text.holidayCards[1]} tone="stone" size="landscape" image="/images/valentine.jpg" backgroundPosition="center 45%" />
            </div>
            <ShowcasePlaceholder title={text.holidayCards[2]} tone="olive" size="square" image="/images/jul.jpg" backgroundPosition="center 75%" />
            <ShowcasePlaceholder title={text.holidayCards[3]} tone="amber" size="square" image="/images/paske.jpg" backgroundPosition="center 30%" />
          </div>
        </div>
      </section>

      <section id={gifts.id} class="scroll-mt-28 grid gap-8 lg:grid-cols-[0.88fr,1.12fr] lg:items-center">
        <div>
          <h2 class="font-heading text-4xl leading-tight text-surface-ink sm:text-[3rem]">{gifts.title}</h2>
          <div class="mt-5 space-y-4 text-base leading-8 text-surface-ink/72">
            {giftCopy.map((paragraph: string) => <p>{paragraph}</p>)}
          </div>
          <p class="mt-8 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-primary-600 sm:hidden">
            {locale === 'en' ? 'Put together with care' : 'Sammensat med omtanke'}
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 max-w-md gift-grid-mobile">
            <ShowcasePlaceholder title={text.giftSplit[0]} tone="rose" size="wide" image="/images/soede-sager.jpg" backgroundPosition="center 70%" zoom={1.45} titleSize="text-base" align="center" />
            <ShowcasePlaceholder title={text.giftSplit[1]} tone="amber" size="wide" align="center" image="/images/gavekurve2.png" backgroundPosition="center 70%" titleSize="text-base" />
            <div class="lg:hidden">
              <ShowcasePlaceholder title={locale === 'en' ? 'Cosmetics' : 'Kosmetik'} tone="stone" size="wide" align="center" image="/images/forside-s-gavekurve.jpg" backgroundPosition="center 70%" titleSize="text-base" />
            </div>
            <div class="lg:hidden">
              <ShowcasePlaceholder title="Romantik" tone="rose" size="wide" align="center" image="/images/romantik.png" backgroundPosition="center" titleSize="text-base" />
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  .holidays-section {
    margin-top: 5rem !important;
  }

  @media (max-width: 639px) {
    .wedding-text-box {
      left: 1.5rem !important;
      right: auto !important;
    }

    .space-y-20 > * + * {
      margin-top: 3.5rem !important;
    }
  }

  @media (max-width: 1023px) {
    .funeral-grid-desktop {
      display: none !important;
    }

    .funeral-slideshow-tablet {
      display: block !important;
    }
  }

  @media (min-width: 640px) {
    .holidays-section {
      margin-top: 0.5rem !important;
    }

    .gift-grid-mobile {
      max-width: none !important;
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .gift-grid-mobile {
      max-width: 16rem;
      grid-template-columns: repeat(2, 1fr);
    }

    .gift-grid-mobile .lg\:hidden {
      display: none !important;
    }

    .gift-grid-mobile > div:first-child {
      transform: translateY(-0.5rem);
    }
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .mobile-slider-arrow {
    position: absolute;
    top: 50%;
    z-index: 10;
    display: inline-flex;
    height: 2.4rem;
    width: 2.4rem;
    transform: translateY(-50%);
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(250, 250, 245, 0.92);
    color: #526349;
    box-shadow: 0 10px 24px rgba(26, 28, 25, 0.12);
    backdrop-filter: blur(10px);
  }
</style>

<script>
  document.querySelectorAll('.mobile-slider-arrow').forEach((button) => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-slider-target');
      const slider = targetId ? document.getElementById(targetId) : null;

      if (!slider) return;

      const cards = Array.from(slider.children);
      const cardWidth = Math.round(slider.clientWidth * 0.82);
      const currentIndex = Math.round(slider.scrollLeft / Math.max(cardWidth, 1));
      const lastIndex = Math.max(cards.length - 1, 0);
      const isNext = button.classList.contains('mobile-slider-next');

      let targetIndex = currentIndex + (isNext ? 1 : -1);

      if (targetId === 'holiday-slider') {
        if (targetIndex > lastIndex) targetIndex = 0;
        if (targetIndex < 0) targetIndex = lastIndex;
      } else {
        targetIndex = Math.max(0, Math.min(lastIndex, targetIndex));
      }

      const targetCard = cards[targetIndex];

      if (!targetCard) return;

      slider.scrollTo({
        left: targetCard.offsetLeft - slider.offsetLeft,
        behavior: 'smooth',
      });
    });
  });

  // Bryllup slideshow
  const slideshow = document.querySelector('.bryllup-slideshow');
  if (slideshow) {
    let currentSlide = 0;
    const slides = slideshow.querySelectorAll('.bryllup-slide');
    const totalSlides = slides.length;

    setInterval(() => {
      slides[currentSlide].classList.remove('opacity-100');
      slides[currentSlide].classList.add('opacity-0');

      currentSlide = (currentSlide + 1) % totalSlides;

      slides[currentSlide].classList.remove('opacity-0');
      slides[currentSlide].classList.add('opacity-100');
    }, 4000);
  }

  // Funeral slideshow
  const funeralSlideshow = document.querySelector('.funeral-slideshow');
  if (funeralSlideshow) {
    let currentSlide = 0;
    const slides = funeralSlideshow.querySelectorAll('.funeral-slide');
    const totalSlides = slides.length;

    setInterval(() => {
      slides[currentSlide].classList.remove('opacity-100');
      slides[currentSlide].classList.add('opacity-0');

      currentSlide = (currentSlide + 1) % totalSlides;

      slides[currentSlide].classList.remove('opacity-0');
      slides[currentSlide].classList.add('opacity-100');
    }, 4000);
  }
</script>
