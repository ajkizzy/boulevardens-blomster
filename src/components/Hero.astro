---
interface Props {
  heading: string;
  subheading?: string;
  cta1?: { label: string; href: string };
  cta2?: { label: string; href: string };
  image?: string;
  overlay?: boolean;
  compact?: boolean;
}

const {
  heading,
  subheading,
  cta1,
  cta2,
  image,
  overlay = true,
  compact = false,
} = Astro.props;
const isEnglish = Astro.url.pathname.startsWith('/en');
const heroText = isEnglish
  ? {
      badge: 'The Organic Curator',
      cardLabel: 'Editorial floristry',
      chipOne: 'Scandinavian calm',
      chipTwo: 'Botanical warmth',
      cardBody: 'Curated bouquets, crafted with room to breathe.',
    }
  : {
      badge: 'Den organiske kurator',
      cardLabel: 'Editorial floristik',
      chipOne: 'Skandinavisk ro',
      chipTwo: 'Botanisk varme',
      cardBody: 'Kuraterede buketter med plads, ro og personlighed.',
    };
---

<section class:list={[
  "relative overflow-hidden px-4 sm:px-6 lg:px-8",
  compact ? "pb-10 pt-10 sm:pb-12 sm:pt-12" : "pb-12 pt-8 sm:pb-16 sm:pt-10 lg:pb-20"
]}>
  <div class="container-narrow mx-auto">
    <div class:list={[
      "relative overflow-hidden rounded-[2rem] text-white",
      compact ? "px-6 py-12 sm:px-10" : "px-6 py-12 sm:px-10 sm:py-16 lg:px-14 lg:py-20"
    ]} style="background-image:linear-gradient(135deg,#526349 0%,#90a384 100%);">
      {image && (
        <div class="absolute inset-0">
          <img src={image} alt="" class="h-full w-full object-cover opacity-25 mix-blend-soft-light" />
          {overlay && <div class="absolute inset-0 bg-[rgba(26,28,25,0.14)]" />}
        </div>
      )}

      <div class="absolute inset-0 opacity-60">
        <div class="absolute -left-10 top-0 h-48 w-48 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute right-0 top-0 h-56 w-56 rounded-full bg-secondary-200/30 blur-3xl"></div>
        <div class="absolute bottom-0 left-1/3 h-40 w-40 rounded-full bg-accent-100/20 blur-3xl"></div>
      </div>

      <div class:list={[
        "relative grid items-end gap-8",
        compact ? "lg:grid-cols-[1.4fr,0.6fr]" : "lg:grid-cols-[1.15fr,0.85fr]"
      ]}>
        <div class="max-w-3xl">
          <span class="inline-flex items-center rounded-full bg-white/14 px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-white/90">
            {heroText.badge}
          </span>
          <h1 class:list={[
            "mt-6 font-heading font-semibold leading-[0.95] tracking-[-0.02em] text-white",
            compact ? "text-4xl sm:text-5xl" : "text-5xl sm:text-6xl lg:text-[4.8rem]"
          ]}>
            {heading}
          </h1>
          {subheading && (
            <p class:list={[
              "mt-6 max-w-2xl font-body leading-relaxed text-white/86",
              compact ? "text-base sm:text-lg" : "text-lg sm:text-xl"
            ]}>
              {subheading}
            </p>
          )}
          {(cta1 || cta2) && (
            <div class="mt-10 flex flex-col gap-3 sm:flex-row">
              {cta1 && (
                <a href={cta1.href} class="btn-primary !bg-none !px-8 !py-3.5 !text-base">
                  {cta1.label}
                </a>
              )}
              {cta2 && (
                <a href={cta2.href} class="btn-secondary !bg-white/14 !text-white !shadow-none !px-8 !py-3.5 !text-base hover:!bg-white/24">
                  {cta2.label}
                </a>
              )}
            </div>
          )}
        </div>

        <div class:list={[
          "relative hidden min-h-[280px] lg:block",
          compact && "!min-h-[220px]"
        ]}>
          <div class="absolute inset-y-10 right-2 w-[72%] rounded-[2rem] bg-white/12"></div>
          <div class="absolute -left-8 top-8 h-[70%] w-[68%] rounded-[2rem] bg-secondary-100/25 backdrop-blur-sm"></div>
          <div class="absolute bottom-0 right-0 w-[78%] rounded-[1.75rem] bg-[rgba(250,250,245,0.88)] p-6 text-surface-ink shadow-ambient">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary-600">
              {heroText.cardLabel}
            </p>
            <p class="mt-3 font-heading text-2xl leading-tight text-surface-ink">
              {heroText.cardBody}
            </p>
            <div class="mt-6 grid grid-cols-2 gap-3 text-sm text-surface-ink/70">
              <div class="rounded-2xl bg-surface px-4 py-3">{heroText.chipOne}</div>
              <div class="rounded-2xl bg-surface px-4 py-3">{heroText.chipTwo}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
