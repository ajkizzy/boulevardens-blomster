---
interface Props {
  heading: string;
  subheading?: string;
  cta1?: { label: string; href: string };
  cta2?: { label: string; href: string };
  image?: string;
  overlay?: boolean;
  compact?: boolean;
}

const { heading, subheading, cta1, cta2, image, overlay = true, compact = false } = Astro.props;
---

<section class:list={[
  "relative overflow-hidden",
  compact ? "py-16 sm:py-20" : "py-24 sm:py-32 lg:py-40"
]}>
  <!-- Background -->
  {image ? (
    <div class="absolute inset-0">
      <img src={image} alt="" class="w-full h-full object-cover" />
      {overlay && <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/40 to-black/60" />}
    </div>
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900" />
  )}

  <!-- Decorative elements -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl" />
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-accent-300 rounded-full translate-x-1/2 translate-y-1/2 blur-3xl" />
  </div>

  <div class="relative container-narrow mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class:list={[
      "font-heading font-bold text-white leading-tight",
      compact ? "text-3xl sm:text-4xl" : "text-4xl sm:text-5xl lg:text-6xl"
    ]}>
      {heading}
    </h1>
    {subheading && (
      <p class="mt-4 sm:mt-6 text-lg sm:text-xl text-white/90 max-w-2xl mx-auto leading-relaxed font-light">
        {subheading}
      </p>
    )}
    {(cta1 || cta2) && (
      <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        {cta1 && (
          <a href={cta1.href} class="btn-primary !bg-white !text-primary-800 hover:!bg-gray-100 !px-8 !py-3.5 !text-base">
            {cta1.label}
          </a>
        )}
        {cta2 && (
          <a href={cta2.href} class="btn-secondary !border-white !text-white hover:!bg-white hover:!text-primary-800 !px-8 !py-3.5 !text-base">
            {cta2.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
