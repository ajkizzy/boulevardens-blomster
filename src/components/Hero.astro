---
interface Props {
  heading: string;
  subheading?: string;
  cta1?: { label: string; href: string };
  cta2?: { label: string; href: string };
  image?: string;
  objectPosition?: string;
  overlay?: boolean;
  compact?: boolean;
  panelTitle?: string;
  panelBody?: string;
  panelNote?: string | null;
}

const {
  heading,
  subheading,
  cta1,
  cta2,
  image,
  objectPosition,
  overlay = true,
  compact = false,
  panelTitle,
  panelBody,
  panelNote,
} = Astro.props;
const isEnglish = Astro.url.pathname.startsWith('/en');
const heroText = isEnglish
  ? {
      badge: 'Flower shop in Høje Taastrup',
      panelLabel: 'Simple flower ordering',
      panelTitle: 'Bouquets for the office, the reception, and special days.',
      panelBody:
        'Order flowers for colleagues, customers, and everyday moments without making it complicated.',
      panelNote: 'Local delivery in Taastrup and help with larger business orders.',
    }
  : {
      badge: 'Blomsterbutik i Høje Taastrup',
      panelLabel: 'Nem blomsterbestilling',
      panelTitle: 'Buketter til kontoret, receptionen og de særlige dage.',
      panelBody:
        'Bestil blomster til kolleger, kunder og hverdagens små og store øjeblikke uden bøvl.',
      panelNote: 'Lokal levering i Taastrup og hjælp til større firmabestillinger.',
    };
const resolvedPanelTitle = panelTitle ?? heroText.panelTitle;
const resolvedPanelBody = panelBody ?? heroText.panelBody;
const resolvedPanelNote =
  panelNote === null ? null : (panelNote ?? heroText.panelNote);
---

<section
  class:list={[
    'relative overflow-x-clip overflow-y-hidden px-4 sm:px-6 lg:px-8',
    compact ? 'pb-8 pt-8 sm:pb-10 sm:pt-10' : 'pb-8 pt-6 sm:pb-10 sm:pt-8 lg:pb-12',
  ]}
>
  <div class="container-narrow mx-auto">
    <div
      class:list={[
        'relative overflow-hidden rounded-[2rem] text-white',
        compact ? 'px-6 py-10 sm:px-10 sm:py-11' : 'px-6 py-10 sm:px-10 sm:py-12 lg:px-14 lg:py-14',
      ]}
    >
      {image && (
        <div class="absolute inset-0">
          <img src={image} alt="" class="h-full w-full object-cover" style={objectPosition ? `object-position: ${objectPosition}; filter: blur(2px)` : 'filter: blur(2px)'} />
          <div class="absolute inset-0 bg-primary-600/80"></div>
        </div>
      )}


      <div
        class:list={[
          'relative grid items-end gap-8',
          compact ? 'lg:grid-cols-[1fr,0.9fr] lg:gap-6' : 'lg:grid-cols-[1.15fr,0.85fr]',
        ]}
      >
        <div class="min-w-0 max-w-3xl">
          <span class="inline-flex max-w-full items-center whitespace-normal break-words rounded-full bg-white/14 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/90 sm:text-[0.72rem] sm:tracking-[0.24em]">
            {heroText.badge}
          </span>
          <h1
            class:list={[
              'mt-6 max-w-full break-words font-heading font-semibold leading-[0.95] tracking-[-0.02em] text-white',
              compact ? 'text-[2.55rem] sm:text-5xl' : 'text-[2.9rem] sm:text-6xl lg:text-[4.8rem]',
            ]}
          >
            {heading}
          </h1>
          {subheading && (
            <p
              class:list={[
                'mt-6 max-w-full font-body leading-relaxed text-white/86 sm:max-w-2xl',
                compact ? 'text-base sm:text-lg' : 'text-lg sm:text-xl',
              ]}
            >
              {subheading}
            </p>
          )}
          {(cta1 || cta2) && (
            <div class="mt-8 flex max-w-full flex-col gap-3 sm:mt-10 sm:flex-row">
              {cta1 && (
                <a href={cta1.href} class="btn-primary w-full !px-6 !py-3.5 !text-base !font-semibold sm:w-auto sm:!px-8">
                  {cta1.label}
                </a>
              )}
              {cta2 && (
                <a
                  href={cta2.href}
                  class="btn-secondary w-full !bg-surface-raised !px-6 !py-3.5 !text-base !text-primary-700 !shadow-ambient hover:!bg-surface-low sm:w-auto sm:!px-8"
                >
                  {cta2.label}
                </a>
              )}
            </div>
          )}
        </div>

        <div class:list={['relative hidden min-h-[280px] lg:block', compact && '!min-h-[200px]']}>
          <div class:list={['absolute rounded-[1.8rem] bg-[rgba(250,250,245,0.97)] text-surface-ink', compact ? 'bottom-[-0.5rem] right-3 left-10 p-5' : 'bottom-4 right-6 w-[76%] p-6']}>
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-primary-600/85">
              {heroText.panelLabel}
            </p>
            <p class:list={['mt-3 font-heading leading-tight text-surface-ink', compact ? 'text-[1.9rem]' : 'text-2xl']}>
              {resolvedPanelTitle}
            </p>
            <p class:list={['mt-3 leading-relaxed text-surface-ink/68', compact ? 'text-[0.95rem]' : 'text-sm']}>{resolvedPanelBody}</p>
            {resolvedPanelNote && (
              <p class="mt-4 text-xs font-semibold text-surface-ink/56">{resolvedPanelNote}</p>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
