---
interface Props {
  name: string;
  price: number;
  priceLabel: string;
  id: string;
}

const { name, price, priceLabel, id } = Astro.props;
---

<div class="editorial-card flex items-center gap-4 p-4" data-addon-id={id}>
  <!-- TODO: Replace with actual addon image -->
  <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-[1rem] bg-gradient-to-br from-secondary-100 to-accent-100">
    <span class="text-2xl opacity-40">🍫</span>
  </div>
  <div class="flex-1 min-w-0">
    <h5 class="truncate text-sm font-medium text-surface-ink">{name}</h5>
    <p class="mt-0.5 text-sm font-semibold text-primary-600">
      {price},00 <span class="text-xs font-normal text-surface-ink/46">{priceLabel}</span>
    </p>
  </div>
</div>
