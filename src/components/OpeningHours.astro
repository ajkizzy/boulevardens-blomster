---
import { loadContent } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const site = loadContent<any>(locale, 'site');
const eyebrow = locale === 'en' ? 'Open hours' : 'Åbningstider';
---

<div class="surface-panel p-6 sm:p-8">
  <p class="eyebrow">{eyebrow}</p>
  <h3 class="mt-5 font-heading text-3xl text-surface-ink">{site.hours.title}</h3>
  <dl class="mt-6 space-y-4 text-sm">
    <div class="flex justify-between items-center">
      <dt class="text-surface-ink/66">{site.hours.weekdays.label}</dt>
      <dd class="font-semibold text-surface-ink">{site.hours.weekdays.time}</dd>
    </div>
    <div class="flex justify-between items-center">
      <dt class="text-surface-ink/66">{site.hours.saturday.label}</dt>
      <dd class="font-semibold text-surface-ink">{site.hours.saturday.time}</dd>
    </div>
    <div class="flex justify-between items-center">
      <dt class="text-surface-ink/66">{site.hours.sunday.label}</dt>
      <dd class="font-semibold text-surface-ink">{site.hours.sunday.time}</dd>
    </div>
  </dl>
</div>
