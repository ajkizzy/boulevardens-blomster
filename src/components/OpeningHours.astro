---
import { loadContent } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const site = loadContent<any>(locale, 'site');
---

<div class="surface-panel w-full min-w-0 p-6 sm:p-8">
  <h3 class="font-heading text-[2rem] text-surface-ink sm:text-3xl">{site.hours.title}</h3>
  <dl class="mt-6 space-y-4 text-sm">
    <div class="grid grid-cols-[minmax(0,1fr),auto] items-start gap-3">
      <dt class="min-w-0 text-surface-ink/66">{site.hours.weekdays.label}</dt>
      <dd class="whitespace-nowrap font-semibold text-surface-ink">{site.hours.weekdays.time}</dd>
    </div>
    <div class="grid grid-cols-[minmax(0,1fr),auto] items-start gap-3">
      <dt class="min-w-0 text-surface-ink/66">{site.hours.saturday.label}</dt>
      <dd class="whitespace-nowrap font-semibold text-surface-ink">{site.hours.saturday.time}</dd>
    </div>
    <div class="grid grid-cols-[minmax(0,1fr),auto] items-start gap-3">
      <dt class="min-w-0 text-surface-ink/66">{site.hours.sunday.label}</dt>
      <dd class="whitespace-nowrap font-semibold text-surface-ink">{site.hours.sunday.time}</dd>
    </div>
  </dl>
</div>
