---
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
  home: any;
  site: any;
}

const { locale, home, site } = Astro.props;
const isEnglish = locale === 'en';

const introParagraphs = String(home.intro.text || '')
  .split('\n\n')
  .map((entry) => entry.trim())
  .filter(Boolean)
  .slice(0, 2);

const heroCopy = isEnglish
  ? {
      eyebrow: 'Boulevardens Blomster',
      headingMain: 'Modern flowers',
      headingAccent: 'for every occasion',
      body:
        'A local flower shop in Høje Taastrup with bouquets, gifts, and floral work for everyday moments and special days.',
      primaryCta: { label: 'Order flowers', href: '/en/company-orders' },
      secondaryCta: { label: 'See our services', href: '/en/services' },
    }
  : {
      eyebrow: 'Boulevardens Blomster',
      headingMain: 'Moderne blomster',
      headingAccent: 'til enhver anledning',
      body:
        'En lokal blomsterbutik i Høje Taastrup med buketter, gaver og blomsterarbejde til både hverdag og særlige dage.',
      primaryCta: { label: 'Bestil blomster', href: '/da/firma-bestilling' },
      secondaryCta: { label: 'Se vores services', href: '/da/services' },
    };

const storyCopy = isEnglish
  ? {
      eyebrow: 'About the shop',
      heading: 'Your local flower shop with a focus on quality and calm details',
      linkLabel: 'Read our story',
      linkHref: '/en/about',
      note: 'Flowers carry feeling. We help you make it personal.',
      noteMeta: 'Boulevardens Blomster',
    }
  : {
      eyebrow: 'Om butikken',
      heading: 'Din lokale blomsterhandler med blik for kvalitet og rolige detaljer',
      linkLabel: 'Læs vores historie',
      linkHref: '/da/om-os',
      note: 'Blomster bærer følelser. Vi hjælper dig med at gøre det personligt.',
      noteMeta: 'Boulevardens Blomster',
    };

const expertiseCopy = isEnglish
  ? {
      eyebrow: 'Our expertise',
      heading: 'Flowers for everyday life, celebrations, and the moments that matter',
    }
  : {
      eyebrow: 'Vores ekspertise',
      heading: 'Blomster til hverdag, fejring og de øjeblikke der betyder noget',
    };

const reasons = isEnglish
  ? [
      {
        title: 'Hand-tied with care',
        body: 'Each order is arranged with attention to colour, shape, and the feeling it should leave behind.',
      },
      {
        title: 'Fresh flowers every day',
        body: 'We receive fresh flowers continuously so bouquets stay beautiful longer after delivery.',
      },
      {
        title: 'Fast local delivery',
        body: 'We deliver in Taastrup and help businesses with recurring orders and special requests.',
      },
    ]
  : [
      {
        title: 'Håndbundet med omtanke',
        body: 'Hver bestilling bindes med blik for farver, form og den stemning buketten skal give videre.',
      },
      {
        title: 'Friske blomster hver dag',
        body: 'Vi får løbende friske blomster hjem, så buketterne holder sig flotte længere efter levering.',
      },
      {
        title: 'Hurtig lokal levering',
        body: 'Vi leverer i Taastrup og hjælper virksomheder med både faste bestillinger og særlige ønsker.',
      },
    ];

const contactStripCopy = isEnglish
  ? {
      heading: 'Visit the shop',
      subheading: 'Høje Taastrup Boulevard 55, 2630 Høje Taastrup',
      button: 'Contact us',
      href: '/en/contact',
    }
  : {
      heading: 'Kom forbi butikken',
      subheading: 'Høje Taastrup Boulevard 55, 2630 Høje Taastrup',
      button: 'Kontakt os',
      href: '/da/kontakt',
    };

const heroSlideImages = [
  '/images/Kopi_af_IMG_1197.jpg',
  '/images/Kopi_af_IMG_1433.jpg',
  '/images/Kopi_af_IMG_1798.jpg',
  '/images/Kopi_af_IMG_1939.jpg',
  '/images/Kopi_af_IMG_2204.jpg',
  '/images/Kopi_af_IMG_2530.jpg',
  '/images/Kopi_af_IMG_8311.jpg',
  '/images/Kopi_af_IMG_8869.jpg',
  '/images/Kopi_af_IMG_9371.jpg',
  '/images/Kopi_af_IMG_9389.jpg',
];

const serviceImages = [
  '/images/forside-service-buketter.jpg',
  '/images/forside-s-bryllupper.jpg',
  '/images/forside-s-begravelse.jpg',
  '/images/forside-s-højtider.jpg',
  '/images/forside-s-gavekurve.jpg',
];

const serviceThemes = [
  {
    classes:
      'md:col-span-2 md:min-h-[21rem] bg-[linear-gradient(135deg,#314a38_0%,#688160_55%,#97aa8e_100%)] text-white',
  },
  {
    classes:
      'md:min-h-[21rem] bg-[linear-gradient(135deg,#f2eee7_0%,#d7c4b2_100%)] text-surface-ink',
  },
  {
    classes:
      'bg-[linear-gradient(135deg,#5a3c2c_0%,#9c765a_100%)] text-white',
  },
  {
    classes:
      'bg-[linear-gradient(135deg,#efe4d3_0%,#d0b896_100%)] text-surface-ink',
  },
  {
    classes:
      'bg-[linear-gradient(135deg,#8ca570_0%,#d5dec8_100%)] text-surface-ink',
  },
];

const getBackgroundPosition = (imagePath: string) => {
  if (imagePath.includes('højtider') || imagePath.includes('begravelse')) {
    return 'center 30%';
  }
  if (imagePath.includes('gavekurve')) {
    return 'center 70%';
  }
  return 'center';
};

const serviceCards = home.serviceHighlights.items.map((item: any, index: number) => {
  const image = serviceImages[index % serviceImages.length];
  return {
    ...item,
    href: isEnglish ? `/en/services#${item.anchor}` : `/da/services#${item.anchor}`,
    theme: serviceThemes[index % serviceThemes.length],
    image,
    backgroundPosition: getBackgroundPosition(image),
  };
});

const companyOrderCard = {
  title: isEnglish ? 'Company Orders' : 'Firma Bestilling',
  description: isEnglish ? 'Get flowers delivered for free within Taastrup Municipality' : 'Få blomster overleveret gratis indenfor Taastrup Kommune',
  href: isEnglish ? '/en/company-orders' : '/da/firma-bestilling',
  image: '/images/firma.jpg',
  backgroundPosition: 'center 40%',
};
---

<section class="px-4 pb-1 pt-3 sm:px-6 lg:px-8">
  <div class="container-narrow mx-auto">
    <div class="home-hero-layout">
      <div class="home-hero-copy min-w-0">
        <h1 class="max-w-[7.2ch] font-heading text-[3.4rem] leading-[0.88] tracking-[-0.05em] text-surface-ink sm:max-w-[7ch] sm:text-[4.9rem] lg:max-w-[6.8ch] lg:text-[5.4rem]">
          {heroCopy.headingMain}
          <span class="block font-normal italic">{heroCopy.headingAccent}</span>
        </h1>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={heroCopy.primaryCta.href} class="btn-primary w-full sm:w-auto sm:!px-6">
            {heroCopy.primaryCta.label}
          </a>
          <a href={heroCopy.secondaryCta.href} class="btn-secondary w-full sm:w-auto sm:!px-6">
            {heroCopy.secondaryCta.label}
          </a>
        </div>
      </div>

      <div class="home-hero-frame">
        <div class="home-hero-scene" id="hero-slideshow">
          {heroSlideImages.map((img, index) => (
            <img
              src={img}
              alt="Flowers"
              class="hero-slide absolute h-full w-full object-cover transition-opacity duration-1000"
              style={`opacity: ${index === 0 ? '1' : '0'}`}
              data-index={index}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="px-4 pb-0 sm:hidden">
  <div class="container-narrow mx-auto">
    <div class="rounded-[1.85rem] bg-surface-raised px-6 py-7 shadow-ambient">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary-600">{contactStripCopy.heading}</p>
      <h2 class="mt-4 font-heading text-[2.35rem] leading-[0.95] text-surface-ink">
        {home.intro.heading}
      </h2>
      <p class="mt-4 text-lg leading-8 text-surface-ink">{contactStripCopy.subheading}</p>
      <p class="mt-5 text-lg font-semibold text-surface-ink">{site.phone}</p>

      <div class="mt-7 border-t border-surface-ink/8 pt-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary-600">{site.hours.title}</p>
        <div class="mt-4 space-y-4 text-surface-ink">
          <div>
            <p class="text-lg">{site.hours.weekdays.label}</p>
            <p class="mt-1 text-2xl font-semibold">{site.hours.weekdays.time}</p>
          </div>
          <div>
            <p class="text-lg">{site.hours.saturday.label}</p>
            <p class="mt-1 text-2xl font-semibold">{site.hours.saturday.time}</p>
          </div>
          <div>
            <p class="text-lg">{site.hours.sunday.label}</p>
            <p class="mt-1 text-2xl font-semibold">{site.hours.sunday.time}</p>
          </div>
        </div>
      </div>

      <a href={contactStripCopy.href} class="btn-primary mt-8 w-full justify-center">
        {contactStripCopy.button}
      </a>
    </div>
  </div>
</section>

<section class="px-4 pb-8 sm:px-6 lg:px-8">
  <div class="container-narrow mx-auto">
    <div class="surface-panel px-5 py-5 sm:px-8 sm:py-8 lg:grid lg:grid-cols-[0.9fr,1.1fr] lg:items-center lg:gap-10">
      <div class="home-story-visual">
        <img src="/images/lidt-om-os.jpg" alt="About us" class="h-full w-full object-cover" />
        <div class="home-story-note">
          <p class="font-heading text-lg leading-tight text-white">{storyCopy.note}</p>
          <p class="mt-3 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/78">{storyCopy.noteMeta}</p>
        </div>
      </div>

      <div class="mt-8 lg:mt-0">
        <p class="eyebrow">{storyCopy.eyebrow}</p>
        <h2 class="mt-5 max-w-[14ch] font-heading text-4xl leading-[0.98] tracking-[-0.03em] text-surface-ink sm:text-[3.3rem]">
          {storyCopy.heading}
        </h2>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-surface-ink/70 home-story-text">
          {introParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <a href={storyCopy.linkHref} class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary-600">
          {storyCopy.linkLabel}
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="px-4 pb-10 sm:px-6 lg:px-8">
  <div class="container-narrow mx-auto">
    <p class="eyebrow">{expertiseCopy.eyebrow}</p>
    <h2 class="mt-5 max-w-[16ch] font-heading text-4xl leading-[0.98] tracking-[-0.03em] text-surface-ink sm:text-[3.1rem]">
      {expertiseCopy.heading}
    </h2>

    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {serviceCards.map((item: any, index: number) => (
        <a
          href={item.href}
          class:list={[
            'service-showcase-card group relative flex min-h-[15rem] overflow-hidden rounded-[1.65rem] p-6 shadow-ambient transition-transform duration-300 hover:-translate-y-1',
            !item.image && item.theme.classes,
          ]}
          style={item.image ? `background-image: url('${item.image}'); background-size: cover; background-position: ${item.backgroundPosition};` : undefined}
        >
          {item.image && (
            <div class="absolute inset-0 bg-gradient-to-b from-black/30 to-black/50"></div>
          )}
          {!item.image && (
            <>
              <div class="service-showcase-glow"></div>
              <div class:list={['service-showcase-ornament', index === 0 && 'service-showcase-ornament-large']}></div>
            </>
          )}
          <div class="relative z-10 mt-auto max-w-[24ch]">
            <h3 class="font-heading text-[2rem] leading-[0.95] text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-white">
              {item.description}
            </p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-white">
              {isEnglish ? 'Explore' : 'Udforsk'}
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}

      <a
        href={companyOrderCard.href}
        class="service-showcase-card group relative flex min-h-[15rem] overflow-hidden rounded-[1.65rem] p-6 shadow-ambient transition-transform duration-300 hover:-translate-y-1"
        style={`background-image: url('${companyOrderCard.image}'); background-size: cover; background-position: ${companyOrderCard.backgroundPosition};`}
      >
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 to-black/50"></div>
        <div class="relative z-10 mt-auto max-w-[24ch]">
          <h3 class="font-heading text-[2rem] leading-[0.95] text-white">{companyOrderCard.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-white">
            {companyOrderCard.description}
          </p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-white">
            {isEnglish ? 'Order' : 'Bestil'}
            <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</section>

<section class="px-4 pb-10 sm:px-6 lg:px-8">
  <div class="container-narrow mx-auto text-center">
    <h2 class="font-heading text-4xl leading-[0.98] tracking-[-0.03em] text-surface-ink sm:text-[2.8rem]">
      {isEnglish ? 'Why choose us?' : 'Hvorfor vælge os?'}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-surface-ink/68">
      {isEnglish
        ? 'We combine classic floristry with a calm and modern expression, so it feels easy to choose flowers that fit the occasion.'
        : 'Vi kombinerer klassisk binderi med et roligt og moderne udtryk, så det er nemt at vælge blomster der passer til anledningen.'}
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {reasons.map((reason) => (
        <div class="rounded-[1.5rem] bg-surface-raised px-5 py-6 shadow-ambient">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-primary-700">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="mt-5 font-heading text-[1.7rem] leading-tight text-surface-ink">{reason.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-surface-ink/68">{reason.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="hidden px-4 pb-14 sm:px-6 lg:block lg:px-8">
  <div class="container-narrow mx-auto rounded-[1.75rem] bg-surface-raised px-5 py-6 shadow-ambient sm:px-8 sm:py-8">
    <div class="grid gap-6 lg:grid-cols-[1.08fr,0.9fr,auto] lg:items-center">
      <div class="min-w-0">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-primary-600">{contactStripCopy.heading}</p>
        <h3 class="mt-3 font-heading text-3xl leading-tight text-surface-ink">{home.intro.heading}</h3>
        <p class="mt-2 text-sm leading-relaxed text-surface-ink/68">{contactStripCopy.subheading}</p>
        <p class="mt-3 text-sm font-semibold text-surface-ink">{site.phone}</p>
      </div>

      <div class="grid gap-2 text-sm text-surface-ink/68 sm:grid-cols-[minmax(0,1fr),auto] sm:items-start sm:gap-3">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary-600">{site.hours.title}</p>
        <div class="hidden sm:block"></div>
        <p>{site.hours.weekdays.label}</p>
        <p class="font-semibold text-surface-ink">{site.hours.weekdays.time}</p>
        <p>{site.hours.saturday.label}</p>
        <p class="font-semibold text-surface-ink">{site.hours.saturday.time}</p>
        <p>{site.hours.sunday.label}</p>
        <p class="font-semibold text-surface-ink">{site.hours.sunday.time}</p>
      </div>

      <a href={contactStripCopy.href} class="btn-primary w-full lg:w-auto">
        {contactStripCopy.button}
      </a>
    </div>
  </div>
</section>

<style>
  .home-hero-layout {
    position: relative;
    min-height: 31.5rem;
  }

  .home-hero-copy {
    position: relative;
    z-index: 2;
    max-width: 32rem;
    padding-top: 4.2rem;
  }

  .home-hero-frame {
    position: absolute;
    right: 0;
    top: 1.2rem;
    overflow: hidden;
    border-radius: 2rem;
    background: #f1efe9;
    box-shadow: 0 24px 60px rgba(26, 28, 25, 0.12);
    width: min(54.4vw, 16.15rem);
  }

  .home-hero-scene {
    position: relative;
    min-height: 29rem;
    overflow: hidden;
    border-radius: 2rem;
  }

  .home-hero-wall {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.92), transparent 32%),
      linear-gradient(180deg, #fbfaf6 0%, #f0ece5 100%);
  }

  .home-hero-table {
    position: absolute;
    inset: auto 0 0 0;
    height: 28%;
    background:
      linear-gradient(180deg, rgba(76, 52, 39, 0.08), rgba(76, 52, 39, 0)),
      linear-gradient(135deg, #6f4f39 0%, #855d42 42%, #5b3e2e 100%);
  }

  .home-hero-shadow {
    position: absolute;
    left: 50%;
    bottom: 20%;
    width: 38%;
    height: 7%;
    transform: translateX(-50%);
    border-radius: 9999px;
    background: rgba(26, 28, 25, 0.16);
    filter: blur(18px);
  }

  .home-hero-vase {
    position: absolute;
    left: 50%;
    bottom: 18%;
    width: 16%;
    height: 28%;
    transform: translateX(-50%);
    border-radius: 1.8rem 1.8rem 2.6rem 2.6rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(226, 236, 228, 0.88)),
      linear-gradient(135deg, rgba(93, 123, 97, 0.12), rgba(255, 255, 255, 0));
    box-shadow: inset 0 0 0 1px rgba(131, 155, 133, 0.28);
  }

  .home-hero-stems {
    position: absolute;
    left: 50%;
    bottom: 20%;
    width: 12%;
    height: 24%;
    transform: translateX(-50%) skewX(-7deg);
    background:
      repeating-linear-gradient(
        90deg,
        rgba(84, 118, 86, 0.95) 0,
        rgba(84, 118, 86, 0.95) 7%,
        rgba(124, 154, 122, 0.96) 7%,
        rgba(124, 154, 122, 0.96) 13%
      );
    clip-path: polygon(24% 0, 76% 0, 100% 100%, 0 100%);
  }

  .home-bloom,
  .home-leaf {
    position: absolute;
    border-radius: 9999px;
  }

  .home-bloom {
    box-shadow: 0 12px 20px rgba(26, 28, 25, 0.08);
  }

  .home-bloom-a {
    left: 39%;
    top: 24%;
    width: 15%;
    height: 15%;
    background: radial-gradient(circle at 35% 35%, #fde7ef 0%, #efb3c8 62%, #d48ba6 100%);
  }

  .home-bloom-b {
    left: 48%;
    top: 20%;
    width: 17%;
    height: 17%;
    background: radial-gradient(circle at 40% 38%, #ffe8ee 0%, #f4bfd0 58%, #e39ab4 100%);
  }

  .home-bloom-c {
    left: 57%;
    top: 25%;
    width: 14%;
    height: 14%;
    background: radial-gradient(circle at 40% 38%, #fff8f2 0%, #f3ece4 50%, #e2d6c7 100%);
  }

  .home-bloom-d {
    left: 31%;
    top: 27%;
    width: 13%;
    height: 13%;
    background: radial-gradient(circle at 40% 38%, #fff9f2 0%, #f1eee9 56%, #ddd4c8 100%);
  }

  .home-bloom-e {
    left: 45%;
    top: 32%;
    width: 12%;
    height: 12%;
    background: radial-gradient(circle at 40% 38%, #fef4f7 0%, #efc8d6 56%, #e4a6bc 100%);
  }

  .home-leaf {
    background: linear-gradient(135deg, #4f7557 0%, #7fa084 100%);
    opacity: 0.95;
  }

  .home-leaf-a {
    left: 28%;
    top: 30%;
    width: 11%;
    height: 21%;
    transform: rotate(-34deg);
    border-radius: 100% 0 100% 0;
  }

  .home-leaf-b {
    right: 21%;
    top: 30%;
    width: 12%;
    height: 22%;
    transform: rotate(28deg);
    border-radius: 100% 0 100% 0;
  }

  .home-leaf-c {
    left: 36%;
    top: 16%;
    width: 8%;
    height: 24%;
    transform: rotate(-12deg);
    border-radius: 100% 0 100% 0;
  }

  .home-leaf-d {
    right: 32%;
    top: 13%;
    width: 7%;
    height: 22%;
    transform: rotate(16deg);
    border-radius: 100% 0 100% 0;
  }

  .home-story-visual {
    position: relative;
    min-height: 23rem;
    overflow: hidden;
    border-radius: 1.8rem;
    background: linear-gradient(135deg, #8a684d 0%, #6c4f39 100%);
    box-shadow: 0 20px 50px rgba(26, 28, 25, 0.12);
  }

  .home-story-background {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.1) 0,
        rgba(255, 255, 255, 0.1) 1px,
        transparent 1px,
        transparent 30px
      ),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(26, 28, 25, 0.12));
  }

  .home-story-overlay {
    position: absolute;
    inset: 13% 14% 18% 8%;
    border-radius: 1.5rem;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 30%),
      linear-gradient(135deg, rgba(58, 42, 31, 0.22), rgba(255, 255, 255, 0.04));
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .home-story-note {
    position: absolute;
    right: 1.25rem;
