---
import { loadContent, getNavLinks, getPathForLocale } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const site = loadContent<any>(locale, 'site');
const nav = getNavLinks(locale);
const currentPath = Astro.url.pathname;
const daPath = getPathForLocale(currentPath, locale, 'da');
const enPath = getPathForLocale(currentPath, locale, 'en');
const studioLabel = locale === 'en' ? 'Florist studio' : 'Blomsteratelier';
---

<header class="sticky top-0 z-50 px-4 pt-4 sm:px-6 lg:px-8">
  <div class="container-narrow mx-auto">
    <div class="glass-panel rounded-[1.75rem] px-5 py-4 sm:px-6">
      <div class="flex items-center justify-between gap-4">
        <a href={nav.home.href} class="group min-w-0">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-surface-ink/45">
            {studioLabel}
          </div>
          <span class="block truncate text-xl font-heading font-semibold text-primary-700 transition-colors group-hover:text-primary-500 sm:text-[1.7rem]">
            Boulevardens Blomster
          </span>
        </a>

        <nav class="hidden lg:flex items-center gap-7">
          <a href={nav.home.href}
             class:list={["nav-link", { "nav-link-active": currentPath === nav.home.href || currentPath === nav.home.href + '/' }]}>
            {nav.home.label}
          </a>
          <a href={nav.about.href}
             class:list={["nav-link", { "nav-link-active": currentPath.includes(nav.about.href) }]}>
            {nav.about.label}
          </a>
          <div class="relative group">
            <a href={nav.services.href}
               class:list={["nav-link inline-flex items-center gap-1.5", { "nav-link-active": currentPath.includes(nav.services.href) }]}>
              {nav.services.label}
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute left-0 top-full hidden pt-4 group-hover:block">
              <div class="glass-panel min-w-[220px] rounded-[1.4rem] px-3 py-3">
                {site.serviceDropdown.map((item: any) => (
                  <a href={`${nav.services.href}#${item.anchor}`}
                     class="block rounded-xl px-4 py-3 text-sm font-medium text-surface-ink/72 transition-colors hover:bg-surface-raised hover:text-primary-600">
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
          <a href={nav.contact.href}
             class:list={["nav-link", { "nav-link-active": currentPath.includes(nav.contact.href) }]}>
            {nav.contact.label}
          </a>
          <a href={nav.order.href} class="btn-primary !px-5 !py-2.5 !text-xs">
            {nav.order.label}
          </a>
          <div class="ml-1 flex items-center gap-4 text-xs font-semibold uppercase tracking-[0.18em] text-surface-ink/52">
            {locale === 'da'
              ? <span class="language-link language-link-active">DA</span>
              : <a href={daPath} class="language-link">DA</a>
            }
            {locale === 'en'
              ? <span class="language-link language-link-active">EN</span>
              : <a href={enPath} class="language-link">EN</a>
            }
          </div>
        </nav>

        <button id="mobile-menu-btn" class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface-low text-primary-600" aria-label="Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden lg:hidden pt-5">
        <div class="editorial-card p-4">
          <nav class="flex flex-col gap-1">
            <a href={nav.home.href} class="mobile-nav-link">{nav.home.label}</a>
            <a href={nav.about.href} class="mobile-nav-link">{nav.about.label}</a>
            <a href={nav.services.href} class="mobile-nav-link">{nav.services.label}</a>
            <div class="grid gap-1 pl-4">
              {site.serviceDropdown.map((item: any) => (
                <a href={`${nav.services.href}#${item.anchor}`}
                   class="mobile-nav-link !py-2 text-sm text-surface-ink/60">
                  {item.label}
                </a>
              ))}
            </div>
            <a href={nav.contact.href} class="mobile-nav-link">{nav.contact.label}</a>
            <a href={nav.order.href} class="mobile-nav-link !text-primary-600">{nav.order.label}</a>
            <div class="mt-3 flex items-center gap-5 px-3 text-xs font-semibold uppercase tracking-[0.18em] text-surface-ink/52">
              {locale === 'da'
                ? <span class="language-link language-link-active">DA</span>
                : <a href={daPath} class="language-link">DA</a>
              }
              {locale === 'en'
                ? <span class="language-link language-link-active">EN</span>
                : <a href={enPath} class="language-link">EN</a>
              }
            </div>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
    padding-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(26, 28, 25, 0.68);
    transition: color 180ms ease;
  }

  .nav-link:hover {
    color: #526349;
  }

  .nav-link-active {
    color: #1a1c19;
  }

  .nav-link-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.15rem;
    height: 2px;
    border-radius: 9999px;
    background: rgba(82, 99, 73, 0.9);
  }

  .mobile-nav-link {
    display: block;
    border-radius: 0.75rem;
    padding: 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(26, 28, 25, 0.72);
    transition:
      background-color 180ms ease,
      color 180ms ease;
  }

  .mobile-nav-link:hover {
    background: #f4f4ef;
    color: #526349;
  }

  .language-link {
    position: relative;
    padding-bottom: 0.5rem;
    transition: color 180ms ease;
  }

  .language-link:hover {
    color: #1a1c19;
  }

  .language-link-active {
    color: #1a1c19;
  }

  .language-link-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.02rem;
    height: 2px;
    border-radius: 9999px;
    background: rgba(82, 99, 73, 0.72);
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
