---
import { loadContent, getNavLinks, getPathForLocale } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const site = loadContent<any>(locale, 'site');
const nav = getNavLinks(locale);
const currentPath = Astro.url.pathname;
const daPath = getPathForLocale(currentPath, locale, 'da');
const enPath = getPathForLocale(currentPath, locale, 'en');
---

<header class="bg-white/95 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-50">
  <div class="container-narrow mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href={nav.home.href} class="flex items-center gap-2 group">
        <span class="text-xl sm:text-2xl font-heading font-semibold text-primary-800 group-hover:text-primary-600 transition-colors">
          Boulevardens Blomster
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <a href={nav.home.href}
           class:list={["nav-link", { "nav-link-active": currentPath === nav.home.href || currentPath === nav.home.href + '/' }]}>
          {nav.home.label}
        </a>
        <a href={nav.about.href}
           class:list={["nav-link", { "nav-link-active": currentPath.includes(nav.about.href) }]}>
          {nav.about.label}
        </a>

        <!-- Services dropdown -->
        <div class="relative group">
          <a href={nav.services.href}
             class:list={["nav-link inline-flex items-center gap-1", { "nav-link-active": currentPath.includes(nav.services.href) }]}>
            {nav.services.label}
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-gray-100 py-2 min-w-[200px]">
              {site.serviceDropdown.map((item: any) => (
                <a href={`${nav.services.href}#${item.anchor}`}
                   class="block px-4 py-2 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-700 transition-colors">
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href={nav.contact.href}
           class:list={["nav-link", { "nav-link-active": currentPath.includes(nav.contact.href) }]}>
          {nav.contact.label}
        </a>
        <a href={nav.order.href}
           class="ml-2 btn-primary !py-2 !px-4 !text-xs">
          {nav.order.label}
        </a>

        <!-- Language switcher -->
        <div class="ml-4 flex items-center gap-1 text-xs font-medium text-gray-500">
          {locale === 'da'
            ? <span class="text-primary-700 font-semibold">DA</span>
            : <a href={daPath} class="hover:text-gray-700">DA</a>
          }
          <span class="text-gray-300">|</span>
          {locale === 'en'
            ? <span class="text-primary-700 font-semibold">EN</span>
            : <a href={enPath} class="hover:text-gray-700">EN</a>
          }
        </div>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-600 hover:text-gray-900" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <nav class="flex flex-col gap-1">
        <a href={nav.home.href} class="mobile-nav-link">{nav.home.label}</a>
        <a href={nav.about.href} class="mobile-nav-link">{nav.about.label}</a>
        <a href={nav.services.href} class="mobile-nav-link">{nav.services.label}</a>
        <div class="pl-4 flex flex-col gap-1">
          {site.serviceDropdown.map((item: any) => (
            <a href={`${nav.services.href}#${item.anchor}`}
               class="mobile-nav-link text-gray-500 !text-xs">
              {item.label}
            </a>
          ))}
        </div>
        <a href={nav.contact.href} class="mobile-nav-link">{nav.contact.label}</a>
        <a href={nav.order.href} class="mobile-nav-link font-semibold text-primary-700">{nav.order.label}</a>
        <div class="flex items-center gap-2 px-3 pt-2 text-xs font-medium text-gray-500">
          {locale === 'da'
            ? <span class="text-primary-700 font-semibold">DA</span>
            : <a href={daPath} class="hover:text-gray-700">DA</a>
          }
          <span class="text-gray-300">|</span>
          {locale === 'en'
            ? <span class="text-primary-700 font-semibold">EN</span>
            : <a href={enPath} class="hover:text-gray-700">EN</a>
          }
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  .nav-link {
    @apply px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 rounded-md transition-colors;
  }
  .nav-link-active {
    @apply text-primary-700 bg-primary-50;
  }
  .mobile-nav-link {
    @apply px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary-700 hover:bg-primary-50 rounded-md transition-colors;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
