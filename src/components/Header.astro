---
import { loadContent, getNavLinks, getPathForLocale } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const site = loadContent<any>(locale, 'site');
const nav = getNavLinks(locale);
const currentPath = Astro.url.pathname;
const daPath = getPathForLocale(currentPath, locale, 'da');
const enPath = getPathForLocale(currentPath, locale, 'en');
---

<header class="sticky top-0 z-50 px-4 pt-4 sm:px-6 lg:px-8 relative">
  <div class="container-narrow mx-auto relative">
    <img
      src="/images/header-red-rose.png"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute left-0 top-[49%] z-50 h-20 w-auto -translate-y-1/2 -rotate-[4deg] -ml-4 sm:h-24 sm:-ml-6 lg:-ml-7"
    />
    <div class="glass-panel rounded-[1.75rem] px-5 py-4 sm:px-6 relative z-40" style="background-color: rgba(250, 250, 245, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px)">
      <div class="flex items-center justify-between gap-4">
        <a href={nav.home.href} class="group flex min-w-0 items-center" aria-label={`${site.name} front page`}>
          <img
            src="/images/logo-jpeg.jpg"
            alt={site.name}
            class="h-11 w-auto max-w-[13rem] rounded-[0.35rem] object-contain transition-opacity group-hover:opacity-85 sm:h-14 sm:max-w-[17rem]"
          />
        </a>

        <nav class="hidden items-center gap-7 lg:flex">
          <a
            href={nav.home.href}
            class:list={['nav-link', { 'nav-link-active': currentPath === nav.home.href || currentPath === `${nav.home.href}/` }]}
          >
            {nav.home.label}
          </a>
          <a
            href={nav.about.href}
            class:list={['nav-link', { 'nav-link-active': currentPath.includes(nav.about.href) }]}
          >
            {nav.about.label}
          </a>
          <div class="group relative">
            <a
              href={nav.services.href}
              class:list={[
                'nav-link inline-flex items-center gap-1.5',
                { 'nav-link-active': currentPath.includes(nav.services.href) },
              ]}
            >
              {nav.services.label}
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute left-0 top-full hidden pt-4 group-hover:block">
              <div class="glass-panel min-w-[240px] rounded-[1.4rem] px-3 py-3">
                {site.serviceDropdown.map((item: any) => (
                  <a
                    href={`${nav.services.href}#${item.anchor}`}
                    class="block rounded-xl px-4 py-3 text-sm font-medium text-surface-ink/72 transition-colors hover:bg-surface-raised hover:text-primary-600"
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
          <a
            href={nav.contact.href}
            class:list={['nav-link', { 'nav-link-active': currentPath.includes(nav.contact.href) }]}
          >
            {nav.contact.label}
          </a>
          <a href={nav.order.href} class="btn-primary !min-w-[10.5rem] !px-6 !py-3.5 !text-[0.95rem] !font-bold">
            {nav.order.label}
          </a>
          <div class="ml-1 flex items-center gap-4 text-xs font-semibold uppercase tracking-[0.18em] text-surface-ink/52">
            {locale === 'da' ? <span class="language-link language-link-active">DA</span> : <a href={daPath} class="language-link">DA</a>}
            {locale === 'en' ? <span class="language-link language-link-active">EN</span> : <a href={enPath} class="language-link">EN</a>}
          </div>
        </nav>

        <button id="mobile-menu-btn" class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-surface-low text-primary-600 lg:hidden" aria-label="Menu">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden pt-5 lg:hidden">
        <div class="surface-panel p-4">
          <nav class="flex flex-col gap-1">
            <a href={nav.home.href} class="mobile-nav-link">{nav.home.label}</a>
            <a href={nav.about.href} class="mobile-nav-link">{nav.about.label}</a>
            <div class="flex items-center gap-2">
              <a
                href={nav.services.href}
                class:list={[
                  'mobile-nav-link flex-1',
                  { '!text-primary-600': currentPath.includes(nav.services.href) },
                ]}
              >
                {nav.services.label}
              </a>
              <button
                id="mobile-services-btn"
                type="button"
                class="inline-flex h-[46px] w-[46px] flex-shrink-0 items-center justify-center rounded-xl bg-surface-raised text-surface-ink/72 transition-colors hover:bg-surface hover:text-primary-600"
                aria-expanded="false"
                aria-controls="mobile-services-menu"
                aria-label={locale === 'en' ? 'Open services menu' : 'Åbn services-menu'}
              >
                <svg class="mobile-services-icon h-4 w-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </div>
            <div id="mobile-services-menu" class="hidden grid gap-1 pl-4">
              {site.serviceDropdown.map((item: any) => (
                <a
                  href={`${nav.services.href}#${item.anchor}`}
                  class="mobile-nav-link !py-2 text-sm text-surface-ink/60"
                >
                  {item.label}
                </a>
              ))}
            </div>
            <a href={nav.contact.href} class="mobile-nav-link">{nav.contact.label}</a>
            <a href={nav.order.href} class="mobile-nav-link !text-primary-600">{nav.order.label}</a>
            <div class="mt-3 flex items-center gap-5 px-3 text-xs font-semibold uppercase tracking-[0.18em] text-surface-ink/52">
              {locale === 'da' ? <span class="language-link language-link-active">DA</span> : <a href={daPath} class="language-link">DA</a>}
              {locale === 'en' ? <span class="language-link language-link-active">EN</span> : <a href={enPath} class="language-link">EN</a>}
            </div>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
    padding-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(26, 28, 25, 0.68);
    transition: color 180ms ease;
  }

  .nav-link.inline-flex {
    align-items: center;
    transform: translateY(-1px);
  }

  .nav-link:hover {
    color: #526349;
  }

  .nav-link-active {
    color: #1a1c19;
  }

  .nav-link-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.15rem;
    height: 2px;
    border-radius: 9999px;
    background: rgba(82, 99, 73, 0.9);
  }

  .mobile-nav-link {
    display: block;
    border-radius: 0.75rem;
    padding: 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(26, 28, 25, 0.72);
    transition:
      background-color 180ms ease,
      color 180ms ease;
  }

  .mobile-nav-link:hover {
    background: #f4f4ef;
    color: #526349;
  }

  .language-link {
    position: relative;
    padding-bottom: 0.5rem;
    transition: color 180ms ease;
  }

  .language-link:hover {
    color: #1a1c19;
  }

  .language-link-active {
    color: #1a1c19;
  }

  .language-link-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.02rem;
    height: 2px;
    border-radius: 9999px;
    background: rgba(82, 99, 73, 0.72);
  }

  .mobile-services-open {
    transform: rotate(180deg);
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const servicesBtn = document.getElementById('mobile-services-btn');
  const servicesMenu = document.getElementById('mobile-services-menu');
  const servicesIcon = servicesBtn?.querySelector('.mobile-services-icon');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  servicesBtn?.addEventListener('click', () => {
    const isOpen = !servicesMenu?.classList.contains('hidden');
    servicesMenu?.classList.toggle('hidden', isOpen);
    servicesBtn.setAttribute('aria-expanded', String(!isOpen));
    servicesIcon?.classList.toggle('mobile-services-open', !isOpen);
  });
</script>
